---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseDetailFrame from '../../components/CourseDetailFrame.astro';
import MermaidZoom from '../../components/MermaidZoom.astro';

export async function getStaticPaths() {
  // Rute chapter Redis dinamis: SEMUA modul koleksi `redis` (6 chapter hasil chunk
  // dari monolit courses/redis.mdx). Track terpisah dari 73 modul Go Luminas, dari
  // `courses`, `aws`, `git`, dan `docker`. Urutkan menurut `order` frontmatter agar
  // konsisten dengan urutan kurikulum 01..06. prev/next dihitung HANYA di dalam koleksi ini.
  const mods = (await getCollection('redis')).sort(
    (a, b) => a.data.order - b.data.order
  );
  const toLink = (m) =>
    m ? { id: m.id, topTitle: m.data.topTitle, badge: m.data.badge } : null;
  return mods.map((mod, i) => ({
    params: { slug: mod.id },
    props: { mod, prev: toLink(mods[i - 1]), next: toLink(mods[i + 1]) },
  }));
}

const { mod, prev, next } = Astro.props;
const { Content } = await render(mod);
const d = mod.data;

// Eyebrow — frame d4lirQ node bpX0n: "COURSE · REDIS" (mono, accent, uppercase).
// `target` di frontmatter (mis. "Course · Redis") dipakai apa adanya dan di-upper-case
// lewat CSS. Fallback ke "Course · {badge}" bila target kosong.
const eyebrow = d.target ?? `Course · ${d.badge}`;

// Meta chips (frame node azTPF). Hanya `readingTime` yang tersedia sebagai data
// nyata di frontmatter; chip lain bersifat khusus-konten sehingga TIDAK
// diada-adakan. Tampilkan chip "Read" saja.
const metaChips = d.readingTime
  ? [{ key: 'Read', value: d.readingTime }]
  : [];
---
<BaseLayout title={d.title} nav={{ variant: 'home', readerControls: true }}>
  <CourseDetailFrame
    toc={d.toc}
    prev={prev}
    next={next}
    basePath="/redis"
    moduleId={mod.id}
  >
    <Fragment slot="header">
      <p class="ca-eyebrow">{eyebrow}</p>
      <h1 class="ca-title" set:html={d.topTitle} />
      <p class="ca-lede">{d.summary}</p>
      {metaChips.length > 0 && (
        <div class="ca-meta">
          {metaChips.map((chip) => (
            <span class="ca-chip">
              <span class="ca-chip-k">{chip.key}</span>
              <span class="ca-chip-v">{chip.value}</span>
            </span>
          ))}
        </div>
      )}
    </Fragment>

    <hr class="ca-rule" />

    <div class="ca-body">
      <Content />
    </div>
  </CourseDetailFrame>

  {/* Mermaid: tombol "Perbesar" + overlay fullscreen (pan & zoom). Skrip-nya
      reusable — sumber yang sama dipakai ModuleLayout, jadi perilaku zoom
      diagram konsisten di lesson maupun course. */}
  <MermaidZoom />
</BaseLayout>

<style>
  /* Eyebrow (node bpX0n) — mono 12 / 600, accent, +1.5 tracking, uppercase. */
  .ca-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--blue-bright);
  }

  /* Title (node zCVLx) — Fraunces 46 / 600, -1 tracking, line-height 1.08. */
  .ca-title {
    margin: 18px 0 0;
    font-family: var(--font-display);
    font-size: clamp(34px, 4.4vw, 46px);
    font-weight: 600;
    letter-spacing: -1px;
    line-height: 1.08;
    color: var(--ink);
  }

  /* Lede (node o9J5lW) — Inter 18 / 500, muted, line-height 1.6. */
  .ca-lede {
    margin: 22px 0 0;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.6;
    color: var(--ink-muted);
  }

  /* Meta chips (frame azTPF) — gap 12, padding-top 28. */
  .ca-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 28px 0 0;
  }
  /* Chip (frame BPg59) — card fill, hairline, radius 9, pad 9/14. */
  .ca-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 14px;
    border: 1px solid var(--line);
    border-radius: 9px;
    background: var(--paper);
  }
  .ca-chip-k {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--faint);
  }
  .ca-chip-v {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--blue);
  }

  /* Hairline antara header dan body (node IiMCF, 1px var(--line)). */
  .ca-rule {
    height: 0;
    margin: 40px 0 0;
    border: 0;
    border-top: 1px solid var(--line);
  }

  /* Body MDX — beri jarak atas; styling konten dari globals.css (Phase 1b). */
  .ca-body {
    margin-top: 40px;
  }

  @media (max-width: 920px) {
    /* Jarak header→TOC→rule→body kini diatur row-gap grid; rule cukup
       menempel di atas body (gap di atasnya dari grid). */
    .ca-rule {
      margin-top: 0;
    }
    .ca-body {
      margin-top: 28px;
    }
  }
  @media (max-width: 680px) {
    .ca-lede {
      font-size: 16px;
    }
  }
</style>
