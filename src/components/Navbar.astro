---
// Navbar generik — dipakai homepage & semua modul.
// Brand (logo + nama situs) SELALU jadi link ke beranda → jalan pulang yang konsisten.
// Module switcher: lompat ke modul mana pun dari halaman mana pun (Popover API).
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  variant: 'home' | 'module';
  badge?: string; // badge brand situs (generik), opsional
  siteName?: string; // nama situs di wordmark
  moduleTitle?: string; // konteks halaman saat di modul (dipakai sbg fallback judul)
  moduleSub?: string;
  summaryHref?: string;
  fontControls?: boolean;
  readerControls?: boolean;
  toc?: boolean;
}
const {
  variant,
  siteName = 'Web Artisan',
  summaryHref,
  fontControls = false,
  readerControls = false,
  toc = false,
} = Astro.props;

// Wordmark dua-warna: kata terakhir di-aksen (mis. Web Artisan -> "Artisan" di-aksen).
const words = siteName.trim().split(/\s+/);
const lead = words.slice(0, -1).join(' ');
const tail = words[words.length - 1];

const path = Astro.url.pathname.replace(/\/$/, '');
// Switcher sadar-konteks:
//  - Konteks LUMINA satu-halaman (/luminas/http|openapi|redis): tampilkan luminas.
//  - Konteks GO-LUMINAS (/go-luminas/*) DAN landing Go Luminas (/luminas/go-luminas):
//    tampilkan 73 modul (koleksi modules) dikelompokkan jadi 9 tahap/chapter,
//    karena Go Luminas membungkus seluruh modules.
const isGoLuminasContext =
  path.startsWith('/go-luminas/') ||
  path.startsWith('/luminas/go-luminas');
const isCourseContext =
  path.startsWith('/luminas/') &&
  path !== '/luminas' &&
  path !== '/luminas/go-luminas';

// Pilih koleksi sesuai konteks. Schema keduanya sama, jadi dipakai seragam.
// Konteks course satu-halaman EXCLUDE go-luminas (ditangani sebagai lesson/modules).
const mods = isCourseContext
  ? (await getCollection('luminas'))
      .filter((c) => c.id !== 'go-luminas')
      .sort((a, b) => a.data.order - b.data.order)
  : (await getCollection('modules')).sort((a, b) => a.data.order - b.data.order);

const basePath = isCourseContext ? '/luminas' : '/go-luminas';
const switcherTitle = isCourseContext ? 'Pindah ke lumina' : 'Pindah ke modul';
const unitLabel = isCourseContext ? 'lumina' : 'modul';

const current = mods.find((m) => path === `${basePath}/${m.id}`) ?? null;
const switchLabel = current
  ? current.data.topTitle
  : isCourseContext
    ? 'Semua lumina'
    : 'Semua modul';
const fallbackHref = current
  ? `${basePath}/${current.id}`
  : isCourseContext
    ? '/luminas'
    : '/luminas/go-luminas#kurikulum';
// Hanya relevan untuk roadmap; course id (mis. "redis-dasar") tidak cocok pola r<digit>.
const currentRoadmapNum =
  current && !isCourseContext
    ? parseInt(current.id.match(/^r(\d+)/)?.[1] ?? '0', 10)
    : null;

// Kelompokkan item untuk switcher. Roadmap dikelompokkan per nomor (r1, r2, ...);
// lumina tidak punya pola itu → dijadikan satu grup tunggal berlabel "Lumina".
type NssGroup = { num: number; name: string; modules: typeof mods };
const nssMap = new Map<number, NssGroup>();
for (const mod of mods) {
  if (isCourseContext) {
    const COURSE_KEY = 0;
    if (!nssMap.has(COURSE_KEY)) {
      nssMap.set(COURSE_KEY, { num: COURSE_KEY, name: 'Lumina', modules: [] });
    }
    nssMap.get(COURSE_KEY)!.modules.push(mod);
    continue;
  }
  const idMatch = mod.id.match(/^r(\d+)/);
  const roadmapNum = idMatch ? parseInt(idMatch[1]) : 99;
  const targetParts = mod.data.target?.split('·') ?? [];
  const roadmapName = targetParts[1]?.trim() ?? `Expedition ${roadmapNum}`;
  if (!nssMap.has(roadmapNum)) {
    nssMap.set(roadmapNum, { num: roadmapNum, name: roadmapName, modules: [] });
  }
  nssMap.get(roadmapNum)!.modules.push(mod);
}
const nssGroups = Array.from(nssMap.values()).sort((a, b) => a.num - b.num);
---
<header class="topbar">
  <div class="topbar-inner">
    {toc && (
      <button
        type="button"
        class="nav-menu-btn"
        data-toc-toggle
        aria-label="Buka daftar isi"
        aria-expanded="false"
        aria-controls="toc-nav"
      >
        <Icon name="menu" size={20} />
      </button>
    )}

    <a class="nav-brand" href="/" aria-label="Ke beranda, semua modul" title="Beranda">
      <span class="logo-badge" aria-hidden="true">
        <img src="/logo.webp" alt="" width="38" height="38" decoding="async" />
      </span>
      <span class="nav-wordmark">{lead}{lead && ' '}<span class="nav-wordmark-accent">{tail}</span></span>
    </a>

    {variant === 'module' && (
    <div class="nav-switch">
      <button
        type="button"
        class="nav-switch-btn"
        popovertarget="mod-switcher"
        aria-controls="mod-switcher"
        aria-expanded="false"
        aria-label={current ? `Modul aktif: ${switchLabel}. Buka navigasi modul` : 'Buka navigasi modul'}
      >
        <Icon name="grid" size={16} class="nav-switch-glyph" />
        <span class="nav-switch-label">{switchLabel}</span>
        <Icon name="chevron-down" size={15} class="nav-switch-caret" />
      </button>
      <a class="nav-switch-fallback" href={fallbackHref}>
        <Icon name="grid" size={16} class="nav-switch-glyph" />
        <span>{current ? `Buka ${unitLabel} ini` : isCourseContext ? 'Lihat semua lumina' : 'Lihat kurikulum'}</span>
      </a>
      <div id="mod-switcher" popover="auto" class="nav-switch-menu">
        <div class="nss-panel">
          <div class="nss-head">
            <div>
              <p class="nss-kicker" id="mod-switcher-title">{switcherTitle}</p>
              <p class="nss-meta">
                <span>{mods.length} {unitLabel}</span>
                <span aria-hidden="true">·</span>
                <span data-module-progress-summary>Progress tersimpan di browser ini</span>
              </p>
            </div>
            <label class="nss-search" aria-label="Cari modul">
              <Icon name="search" size={14} class="nss-search-icon" />
              <input
                type="search"
                class="nss-search-input"
                placeholder={isCourseContext ? 'Cari lumina atau badge' : 'Cari modul atau badge'}
                autocomplete="off"
                spellcheck="false"
                data-module-filter
              />
            </label>
          </div>

          <nav class="nss-nav" aria-labelledby="mod-switcher-title">
            {nssGroups.map((group) => (
              <section
                class={`nss-group-block${currentRoadmapNum === group.num ? ' is-current-roadmap' : ''}`}
                data-roadmap-group
                data-roadmap-name={(isCourseContext ? group.name : `R${group.num} ${group.name}`).toLowerCase()}
              >
                <div class="nss-group-head">
                  <p class="nss-group">{isCourseContext ? group.name : `R${group.num} · ${group.name}`}</p>
                  <p class="nss-group-meta">
                    <span>{group.modules.length} {unitLabel}</span>
                    <span aria-hidden="true">·</span>
                    <span data-roadmap-progress>0 selesai</span>
                  </p>
                </div>
                <div class="nss-list">
                {group.modules.map((m) => (
                  <a
                    href={`${basePath}/${m.id}`}
                    class={`nss-item${current && current.id === m.id ? ' is-current' : ''}`}
                    aria-current={current && current.id === m.id ? 'page' : undefined}
                    data-module-id={m.id}
                    data-module-title={m.data.topTitle.toLowerCase()}
                    data-module-badge={m.data.badge.toLowerCase()}
                    data-search-text={`${group.name} ${m.data.badge} ${m.data.topTitle}`.toLowerCase()}
                  >
                    <span class="nss-badge" aria-hidden="true">{m.data.badge}</span>
                    <span class="nss-body">
                      <span class="nss-title">{m.data.topTitle}</span>
                      <span class="nss-sub">{m.data.readingTime ? m.data.readingTime.replace(' baca', '') : ''}</span>
                    </span>
                    <span class="nss-state" data-module-state hidden>
                      {current && current.id === m.id ? 'Aktif' : ''}
                    </span>
                  </a>
                ))}
                </div>
              </section>
            ))}
            <p class="nss-empty" data-module-empty hidden>Tidak ada {unitLabel} yang cocok dengan kata kunci ini.</p>
          </nav>
        </div>
      </div>
    </div>
    )}

    <div class="topbar-actions">
      <nav class="nav-primary" aria-label="Navigasi utama">
        <a
          class={`nav-item nav-link${path === '/expeditions' || path.startsWith('/expeditions/') ? ' is-active' : ''}`}
          href="/expeditions"
          aria-current={path === '/expeditions' || path.startsWith('/expeditions/') ? 'page' : undefined}
        >Expeditions</a>
        <a
          class={`nav-item nav-link${path === '/luminas' || path.startsWith('/luminas/') ? ' is-active' : ''}`}
          href="/luminas"
          aria-current={path === '/luminas' || path.startsWith('/luminas/') ? 'page' : undefined}
        >Luminas</a>
        <a
          class={`nav-item nav-link${path === '/pictos' || path.startsWith('/pictos/') ? ' is-active' : ''}`}
          href="/pictos"
          aria-current={path === '/pictos' || path.startsWith('/pictos/') ? 'page' : undefined}
        >Pictos</a>
      </nav>
      {readerControls ? (
        <>
          <button type="button" class="rc-btn rc-reader-toggle" popovertarget="reader-panel" aria-controls="reader-panel" aria-expanded="false" aria-label="Pengaturan baca">
            <span class="rc-reader-glyph" aria-hidden="true">Aa</span>
          </button>
          <div id="reader-panel" popover="auto" class="reader-panel">
            <div class="rp-section">
              <p class="rp-label">Tema</p>
              <div class="rp-group" role="group" aria-label="Tema baca">
                <button type="button" class="rp-btn" data-theme-opt="light" aria-label="Tema terang">
                  <Icon name="sun" size={16} />
                  <span>Terang</span>
                </button>
                <button type="button" class="rp-btn" data-theme-opt="reader" aria-label="Tema baca">
                  <Icon name="book" size={16} />
                  <span>Baca</span>
                </button>
                <button type="button" class="rp-btn" data-theme-opt="dark" aria-label="Tema gelap">
                  <Icon name="moon" size={16} />
                  <span>Gelap</span>
                </button>
              </div>
            </div>
            <div class="rp-section">
              <p class="rp-label">Font</p>
              <div class="rp-group" role="group" aria-label="Font baca">
                <button type="button" class="rp-btn" data-font-opt="inter" aria-label="Font Inter">
                  <span class="rp-font-inter">Inter</span>
                </button>
                <button type="button" class="rp-btn" data-font-opt="lora" aria-label="Font Lora">
                  <span class="rp-font-lora">Lora</span>
                </button>
              </div>
            </div>
            <div class="rp-section">
              <p class="rp-label">Ukuran teks</p>
              <div class="rp-group rp-size" role="group" aria-label="Ukuran teks">
                <button type="button" class="rp-btn rp-size-btn" data-font="dec" aria-label="Perkecil ukuran teks">A<Icon name="minus" size={12} class="rc-ic" /></button>
                <button type="button" class="rp-btn rp-size-btn rp-size-reset" data-font="reset" aria-label="Atur ulang ukuran teks">A</button>
                <button type="button" class="rp-btn rp-size-btn" data-font="inc" aria-label="Perbesar ukuran teks">A<Icon name="plus" size={13} class="rc-ic" /></button>
              </div>
            </div>
          </div>
        </>
      ) : (
        <button type="button" class="rc-btn rc-theme" data-theme-toggle aria-label="Ganti tema (Terang / Baca / Gelap)">
          <span class="ti" aria-hidden="true"><Icon name="sun" size={18} /></span>
        </button>
      )}
      <button
        type="button"
        class="nav-burger"
        popovertarget="nav-sheet"
        aria-controls="nav-sheet"
        aria-expanded="false"
        aria-label="Buka menu"
      >
        <Icon name="menu" size={20} />
      </button>
      {variant === 'module' && summaryHref && (
        <a class="topbar-link" href={summaryHref}>Ringkasan</a>
      )}
    </div>
  </div>

  <div id="nav-sheet" popover="auto" class="nav-sheet">
    <a
      class={`nav-sheet-link${path === '/pictos' || path.startsWith('/pictos/') ? ' is-active' : ''}`}
      href="/pictos"
      aria-current={path === '/pictos' || path.startsWith('/pictos/') ? 'page' : undefined}
    >Pictos</a>
    <a
      class={`nav-sheet-link${path === '/expeditions' || path.startsWith('/expeditions/') ? ' is-active' : ''}`}
      href="/expeditions"
      aria-current={path === '/expeditions' || path.startsWith('/expeditions/') ? 'page' : undefined}
    >Expeditions</a>
    <a
      class={`nav-sheet-link${path === '/luminas' || path.startsWith('/luminas/') ? ' is-active' : ''}`}
      href="/luminas"
      aria-current={path === '/luminas' || path.startsWith('/luminas/') ? 'page' : undefined}
    >Luminas</a>
  </div>
</header>

<script is:inline>
  // Posisikan popover switcher tepat di bawah tombolnya (Popover API render di
  // top-layer, jadi default-nya tengah layar). Light-dismiss & Escape ditangani UA.
  (function () {
    var btn = document.querySelector('.nav-switch-btn');
    var menu = document.getElementById('mod-switcher');
    var filter = menu ? menu.querySelector('[data-module-filter]') : null;
    var summary = menu ? menu.querySelector('[data-module-progress-summary]') : null;
    var groups = menu ? Array.prototype.slice.call(menu.querySelectorAll('[data-roadmap-group]')) : [];
    var items = menu ? Array.prototype.slice.call(menu.querySelectorAll('[data-module-id]')) : [];
    var empty = menu ? menu.querySelector('[data-module-empty]') : null;
    if (!btn || !menu || typeof menu.showPopover !== 'function') return;
    function toList(nodes) {
      return Array.prototype.slice.call(nodes || []);
    }
    function normalizeText(value) {
      var text = String(value || '').toLocaleLowerCase('id');
      if (typeof text.normalize === 'function') {
        text = text.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      }
      return text.trim();
    }
    function positionMenu() {
      var r = btn.getBoundingClientRect();
      var w = Math.min(380, window.innerWidth - 24);
      var left = Math.min(r.left, window.innerWidth - w - 12);
      menu.style.width = w + 'px';
      menu.style.left = Math.max(12, left) + 'px';
      menu.style.top = r.bottom + 8 + 'px';
    }
    function syncFilter() {
      var query = filter && 'value' in filter ? normalizeText(filter.value) : '';
      var visibleCount = 0;
      groups.forEach(function (group) {
        var localVisible = 0;
        toList(group.querySelectorAll('[data-module-id]')).forEach(function (item) {
          var haystack = normalizeText(item.getAttribute('data-search-text') || item.textContent || '');
          var match = !query || haystack.indexOf(query) !== -1;
          item.style.display = match ? '' : 'none';
          if (match) {
            localVisible++;
            visibleCount++;
          }
        });
        group.style.display = localVisible === 0 ? 'none' : '';
      });
      if (empty) empty.hidden = visibleCount !== 0;
    }
    function syncProgress() {
      var api = window.moduleProgress;
      if (!api || !items.length) return;
      var ids = items.map(function (item) { return item.getAttribute('data-module-id') || ''; }).filter(Boolean);
      var state = api.getState();
      var doneCount = api.getCompletedCount(ids);
      if (summary) {
        summary.textContent = doneCount + ' dari ' + ids.length + ' modul selesai';
      }
      groups.forEach(function (group) {
        var groupIds = toList(group.querySelectorAll('[data-module-id]'))
          .map(function (item) { return item.getAttribute('data-module-id') || ''; })
          .filter(Boolean);
        var count = groupIds.filter(function (id) { return !!state.completed[id]; }).length;
        var label = group.querySelector('[data-roadmap-progress]');
        if (label) label.textContent = count + ' selesai';
      });
      items.forEach(function (item) {
        var id = item.getAttribute('data-module-id');
        var stateTag = item.querySelector('[data-module-state]');
        if (!id || !stateTag) return;
        var isCurrent = item.getAttribute('aria-current') === 'page';
        var isDone = !!state.completed[id];
        if (isCurrent) stateTag.textContent = 'Aktif';
        else if (isDone) stateTag.textContent = 'Selesai';
        stateTag.hidden = !isCurrent && !isDone;
        item.classList.toggle('is-done', isDone);
      });
    }
    menu.addEventListener('toggle', function () {
      var isOpen = menu.matches(':popover-open');
      btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      if (isOpen) {
        positionMenu();
        syncProgress();
        syncFilter();
        if (filter && typeof filter.focus === 'function') filter.focus({ preventScroll: true });
      }
    });
    menu.addEventListener('beforetoggle', function (e) {
      if (e.newState !== 'open') return;
      positionMenu();
    });
    if (filter) {
      filter.addEventListener('input', syncFilter);
      filter.addEventListener('keyup', syncFilter);
      filter.addEventListener('search', syncFilter);
      filter.addEventListener('change', syncFilter);
    }
    window.addEventListener('module-progress:change', syncProgress);
    window.addEventListener('resize', function () {
      if (menu.matches(':popover-open')) positionMenu();
    });
    window.addEventListener('scroll', function () {
      if (menu.matches(':popover-open')) positionMenu();
    }, { passive: true });
  })();

  // Floating nav: pertegas elevasi saat halaman di-scroll (konten lewat di bawahnya).
  (function () {
    var bar = document.querySelector('.topbar');
    if (!bar) return;
    var on = false;
    function sync() {
      var next = window.scrollY > 6;
      if (next === on) return;
      on = next;
      if (on) bar.setAttribute('data-scrolled', '');
      else bar.removeAttribute('data-scrolled');
    }
    window.addEventListener('scroll', sync, { passive: true });
    sync();
  })();

  // Mobile menu sheet: native popover tidak auto-sync aria-expanded di trigger.
  (function () {
    var sheet = document.getElementById('nav-sheet');
    var burger = document.querySelector('.nav-burger');
    if (!sheet || !burger || typeof sheet.showPopover !== 'function') return;
    sheet.addEventListener('toggle', function () {
      burger.setAttribute('aria-expanded', sheet.matches(':popover-open') ? 'true' : 'false');
    });
  })();

  // Reader panel popover: posisi di bawah tombol Aa, sync aria-expanded.
  (function () {
    var btn = document.querySelector('.rc-reader-toggle');
    var panel = document.getElementById('reader-panel');
    if (!btn || !panel || typeof panel.showPopover !== 'function') return;
    function positionPanel() {
      var r = btn.getBoundingClientRect();
      var w = Math.min(300, window.innerWidth - 24);
      var left = Math.max(12, Math.min(r.right - w, window.innerWidth - w - 12));
      panel.style.width = w + 'px';
      panel.style.left = left + 'px';
      panel.style.top = r.bottom + 8 + 'px';
    }
    panel.addEventListener('toggle', function () {
      btn.setAttribute('aria-expanded', panel.matches(':popover-open') ? 'true' : 'false');
      if (panel.matches(':popover-open')) {
        requestAnimationFrame(positionPanel);
      }
    });
    btn.addEventListener('click', function () {
      if (!panel.matches(':popover-open')) {
        positionPanel();
      }
    });
    window.addEventListener('resize', function () {
      if (panel.matches(':popover-open')) positionPanel();
    });
    window.addEventListener('scroll', function () {
      if (panel.matches(':popover-open')) positionPanel();
    }, { passive: true });
  })();
</script>
