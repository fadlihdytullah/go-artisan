---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseDetailFrame from '../../components/CourseDetailFrame.astro';
import MermaidZoom from '../../components/MermaidZoom.astro';

export async function getStaticPaths() {
  // Rute lesson AWS dinamis: SEMUA modul koleksi `aws` (track terpisah dari 73
  // modul Go Luminas dan dari `courses`). Urutkan menurut `order` frontmatter
  // agar konsisten dengan urutan kurikulum 01..19.
  const mods = (await getCollection('aws')).sort(
    (a, b) => a.data.order - b.data.order
  );
  const toLink = (m) =>
    m ? { id: m.id, topTitle: m.data.topTitle, badge: m.data.badge } : null;
  return mods.map((mod, i) => ({
    params: { slug: mod.id },
    props: { mod, prev: toLink(mods[i - 1]), next: toLink(mods[i + 1]) },
  }));
}

const { mod, prev, next } = Astro.props;
const { Content } = await render(mod);
const d = mod.data;

---
<BaseLayout title={d.title} nav={{ variant: 'home' }}>
  <CourseDetailFrame
    toc={d.toc}
    prev={prev}
    next={next}
    basePath="/aws"
    moduleId={mod.id}
  >
    <Content />
  </CourseDetailFrame>

  {/* Mermaid: tombol "Perbesar" + overlay fullscreen (pan & zoom). Skrip-nya
      reusable — sumber yang sama dipakai ModuleLayout, jadi perilaku zoom
      diagram konsisten di lesson maupun course. */}
  <MermaidZoom />
</BaseLayout>
