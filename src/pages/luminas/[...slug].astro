---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleTOC from '../../components/ArticleTOC.astro';
import MermaidZoom from '../../components/MermaidZoom.astro';

export async function getStaticPaths() {
  // prev/next dihitung HANYA di dalam himpunan courses, terpisah dari roadmap modules.
  // go-luminas DIKECUALIKAN: punya halaman statis khusus (courses/go-luminas.astro)
  // yang membungkus 73 modul, jadi tidak boleh dobel di rute dinamis ini.
  // aws DIKECUALIKAN juga: dilayani wrapper statis (courses/aws.astro) yang
  // membungkus 19 modul koleksi `aws`, bukan renderer mdx dinamis ini.
  // git DIKECUALIKAN juga: di-chunk jadi 7 chapter koleksi `git` dan dilayani
  // wrapper statis (courses/git.astro); entry tipis git.mdx hanya sumber hero.
  // docker DIKECUALIKAN juga: di-chunk jadi 6 chapter koleksi `docker` dan dilayani
  // wrapper statis (courses/docker.astro); entry tipis docker.mdx hanya sumber hero.
  // redis DIKECUALIKAN juga: di-chunk jadi 6 chapter koleksi `redis` dan dilayani
  // wrapper statis (courses/redis.astro); entry tipis redis.mdx hanya sumber hero.
  const courses = (await getCollection('luminas'))
    .filter(
      (c) =>
        c.id !== 'go-luminas' &&
        c.id !== 'aws' &&
        c.id !== 'git' &&
        c.id !== 'docker' &&
        c.id !== 'redis'
    )
    .sort((a, b) => a.data.order - b.data.order);
  return courses.map((course, i) => {
    const toLink = (c) =>
      c ? { id: c.id, topTitle: c.data.topTitle, badge: c.data.badge } : null;
    return {
      params: { slug: course.id },
      props: {
        mod: course,
        prev: toLink(courses[i - 1]),
        next: toLink(courses[i + 1]),
        moduleIndex: i + 1,
        totalModules: courses.length,
        moduleIds: courses.map((item) => item.id),
      },
    };
  });
}

const { mod, prev, next, moduleIndex, totalModules, moduleIds } = Astro.props;
const { Content } = await render(mod);
const d = mod.data;

---
<BaseLayout title={d.title} nav={{ variant: 'home' }}>
  {/* Bordered 1180 column (continuous full-height side hairlines) — lanjut
      menerus ke footer v2 yang dirender BaseLayout di kolom .shell-col yang sama
      (SPEC §3). Body = grid 2 kolom: TOC 330 + artikel. */}
  <div class="shell-bleed">
    <div class="shell-col">
      <div class="article-layout">
        <ArticleTOC toc={d.toc} heading="On this page" />

        <article class="course-article" data-module-root data-module-id={mod.id}>
          <Content />
        </article>
      </div>
    </div>
  </div>

  <a href="#" id="toTop" aria-label="Kembali ke atas" title="Ke atas">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5l0 14" /><path d="M18 11l-6 -6" /><path d="M6 11l6 -6" /></svg>
  </a>

  <script is:inline>
    // Bilah "ke atas" + scroll-spy TOC (mandiri di halaman artikel ini —
    // ModuleLayout TIDAK dipakai di sini, jadi skrip-skripnya tidak ikut).
    (function () {
      // Tombol "ke atas"
      var bt = document.getElementById('toTop');
      function onScroll() {
        var top = document.documentElement.scrollTop;
        if (bt) bt.classList.toggle('show', top > 600);
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Scroll-spy: nyalakan item TOC aktif (ArticleTOC memakai data-toc-link).
      var links = document.querySelectorAll('nav.article-toc a[data-toc-link]');
      var sections = document.querySelectorAll('article.course-article section[id]');
      if (links.length && sections.length && 'IntersectionObserver' in window) {
        var obs = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                links.forEach(function (l) { l.classList.remove('active'); });
                var active = document.querySelector(
                  'nav.article-toc a[href="#' + e.target.id + '"]'
                );
                if (active) active.classList.add('active');
              }
            });
          },
          { rootMargin: '-20% 0px -70% 0px' }
        );
        sections.forEach(function (s) { obs.observe(s); });
      }
    })();
  </script>

  {/* Mermaid: tombol "Perbesar" + overlay fullscreen (pan & zoom). Skrip-nya
      reusable — sumber yang sama dipakai ModuleLayout, jadi perilaku zoom
      diagram konsisten di lesson maupun course. */}
  <MermaidZoom />
</BaseLayout>

<style>
  .article-layout {
    position: relative;
    display: grid;
    grid-template-columns: 330px minmax(0, 1fr);
    grid-template-areas: "toc body";
    align-items: start;
  }

  .article-layout::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 330px;
    width: 1px;
    background: var(--line);
  }

  .article-layout :global(.article-toc) {
    grid-area: toc;
  }

  .course-article {
    grid-area: body;
    min-width: 0;
    padding: 0 56px 64px;
  }

  /* ── Tombol "ke atas" ──────────────────────────────────────── */
  #toTop {
    position: fixed;
    right: 24px;
    bottom: 24px;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: var(--paper);
    color: var(--ink-soft);
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease, background-color 0.15s ease;
    z-index: 40;
  }
  #toTop.show {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  #toTop:hover {
    background: var(--paper-soft);
    color: var(--ink);
  }

  @media (max-width: 920px) {
    .article-layout {
      grid-template-columns: minmax(0, 1fr);
      grid-template-areas:
        "body"
        "toc";
      row-gap: 28px;
    }
    .article-layout::before {
      display: none;
    }
    .course-article {
      padding: 0 28px 56px;
    }
  }
  @media (max-width: 680px) {
    .course-article {
      padding: 0 20px 44px;
    }
  }
</style>
