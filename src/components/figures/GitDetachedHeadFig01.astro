<svg viewBox="0 0 760 330" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Diagram perbandingan HEAD menempel pada branch versus detached HEAD yang menunjuk commit langsung">
  <defs>
    <marker id="gdhArrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#a3461f" />
    </marker>
  </defs>
  <rect x="20" y="20" width="720" height="290" rx="20" fill="#f6fafb" stroke="#cfd8dc" />
  <text x="48" y="54" fill="#0f1f24" font-size="21" font-weight="700">HEAD menempel vs detached HEAD</text>
  <line x1="390" y1="78" x2="390" y2="298" stroke="#cfd8dc" stroke-dasharray="4 5" />

  <!-- Kiri: normal -->
  <text x="56" y="100" fill="#516469" font-size="13.5" font-weight="700">Normal: HEAD menempel pada branch</text>
  <rect x="110" y="116" width="120" height="40" rx="9" fill="#ffffff" stroke="#9aa7ab" />
  <text x="170" y="141" fill="#0f1f24" font-size="14" font-weight="700" text-anchor="middle">HEAD</text>
  <path d="M 170 156 L 170 192" fill="none" stroke="#a3461f" stroke-width="2.4" marker-end="url(#gdhArrow)" />
  <rect x="96" y="194" width="150" height="40" rx="9" fill="#f7e7df" stroke="#a3461f" stroke-width="2" />
  <text x="171" y="219" fill="#a3461f" font-size="14" font-weight="700" text-anchor="middle">branch: main</text>
  <path d="M 171 234 L 171 262" fill="none" stroke="#a3461f" stroke-width="2.4" marker-end="url(#gdhArrow)" />
  <circle cx="171" cy="284" r="16" fill="#f7e7df" stroke="#a3461f" stroke-width="2" />
  <text x="171" y="289" fill="#0f1f24" font-size="11.5" font-weight="700" text-anchor="middle">a1b2</text>

  <!-- Kanan: detached -->
  <text x="420" y="100" fill="#516469" font-size="13.5" font-weight="700">Detached: HEAD menunjuk commit langsung</text>
  <rect x="470" y="116" width="120" height="40" rx="9" fill="#f7e7df" stroke="#a3461f" stroke-width="2" />
  <text x="530" y="141" fill="#0f1f24" font-size="14" font-weight="700" text-anchor="middle">HEAD</text>
  <path d="M 530 156 L 530 262" fill="none" stroke="#a3461f" stroke-width="2.4" marker-end="url(#gdhArrow)" />
  <circle cx="530" cy="284" r="16" fill="#f7e7df" stroke="#a3461f" stroke-width="2" />
  <text x="530" y="289" fill="#0f1f24" font-size="11.5" font-weight="700" text-anchor="middle">9f2c</text>
  <!-- commit baru mengambang -->
  <line x1="546" y1="274" x2="624" y2="222" stroke="#9aa7ab" stroke-width="2.2" stroke-dasharray="4 4" />
  <circle cx="648" cy="206" r="16" fill="#ffffff" stroke="#a3461f" stroke-width="2" stroke-dasharray="4 4" />
  <text x="648" y="170" fill="#a3461f" font-size="12" font-weight="700" text-anchor="middle">commit baru</text>
  <text x="648" y="186" fill="#516469" font-size="11.5" text-anchor="middle">tanpa branch</text>
</svg>
