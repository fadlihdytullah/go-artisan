---
import { getCollection, render } from 'astro:content';
import ModuleLayout from '../../layouts/ModuleLayout.astro';

export async function getStaticPaths() {
  const mods = (await getCollection('modules')).sort(
    (a, b) => a.data.order - b.data.order
  );
  return mods.map((mod, i) => {
    const toLink = (m) =>
      m ? { id: m.id, topTitle: m.data.topTitle, badge: m.data.badge } : null;
    return {
      params: { slug: mod.id },
      props: {
        mod,
        prev: toLink(mods[i - 1]),
        next: toLink(mods[i + 1]),
        moduleIndex: i + 1,
        totalModules: mods.length,
        moduleIds: mods.map((item) => item.id),
      },
    };
  });
}

const { mod, prev, next, moduleIndex, totalModules, moduleIds } = Astro.props;
const { Content } = await render(mod);
const d = mod.data;
---
<ModuleLayout
  moduleId={mod.id}
  moduleIndex={moduleIndex}
  totalModules={totalModules}
  moduleIds={moduleIds}
  title={d.title}
  badge={d.badge}
  topTitle={d.topTitle}
  topSub={d.topSub}
  toc={d.toc}
  summaryHref={d.summaryHref}
  footerTitle={d.footerTitle}
  footerSub={d.footerSub}
  prev={prev}
  next={next}
>
  <Content />
</ModuleLayout>
