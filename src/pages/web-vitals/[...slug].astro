---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseDetailFrame from '../../components/CourseDetailFrame.astro';
import MermaidZoom from '../../components/MermaidZoom.astro';

export async function getStaticPaths() {
  const mods = (await getCollection('webvitals')).sort(
    (a, b) => a.data.order - b.data.order
  );
  const toLink = (m) =>
    m ? { id: m.id, topTitle: m.data.topTitle, badge: m.data.badge } : null;
  return mods.map((mod, i) => ({
    params: { slug: mod.id },
    props: { mod, prev: toLink(mods[i - 1]), next: toLink(mods[i + 1]) },
  }));
}

const { mod, prev, next } = Astro.props;
const { Content } = await render(mod);
const d = mod.data;

---
<BaseLayout title={d.title} nav={{ variant: 'home', readerControls: true }}>
  <CourseDetailFrame
    toc={d.toc}
    prev={prev}
    next={next}
    basePath="/web-vitals"
    moduleId={mod.id}
  >
    <Content />
  </CourseDetailFrame>
  <MermaidZoom />
</BaseLayout>
