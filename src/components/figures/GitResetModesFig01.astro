<svg viewBox="0 0 740 360" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Diagram tiga mode git reset: soft, mixed, hard, dan area mana yang ikut diubah">
  <rect x="20" y="20" width="700" height="320" rx="20" fill="#f6fafb" stroke="#cfd8dc" />
  <text x="44" y="54" fill="#0f1f24" font-size="21" font-weight="700">Tiga mode git reset</text>

  <!-- Header kolom -->
  <text x="265" y="94" fill="#0f1f24" font-size="14" font-weight="700" text-anchor="middle">HEAD</text>
  <text x="265" y="110" fill="#516469" font-size="11.5" text-anchor="middle">(commit)</text>
  <text x="425" y="94" fill="#0f1f24" font-size="14" font-weight="700" text-anchor="middle">Index</text>
  <text x="425" y="110" fill="#516469" font-size="11.5" text-anchor="middle">(staging)</text>
  <text x="585" y="94" fill="#0f1f24" font-size="14" font-weight="700" text-anchor="middle">Working tree</text>
  <line x1="190" y1="120" x2="660" y2="120" stroke="#cfd8dc" />

  <!-- soft -->
  <rect x="190" y="132" width="470" height="40" rx="8" fill="#f5f9fb" stroke="#e2e8f0" />
  <rect x="190" y="132" width="150" height="40" rx="8" fill="#f7e7df" stroke="#a3461f" stroke-width="2" />
  <text x="36" y="157" fill="#0f1f24" font-size="13.5" font-weight="700">git reset --soft</text>
  <text x="265" y="157" fill="#a3461f" font-size="12.5" font-weight="700" text-anchor="middle">dipindah</text>

  <!-- mixed -->
  <rect x="190" y="192" width="470" height="40" rx="8" fill="#f5f9fb" stroke="#e2e8f0" />
  <rect x="190" y="192" width="310" height="40" rx="8" fill="#f7e7df" stroke="#a3461f" stroke-width="2" />
  <text x="36" y="211" fill="#0f1f24" font-size="13.5" font-weight="700">git reset --mixed</text>
  <text x="36" y="228" fill="#516469" font-size="11.5">(default)</text>
  <text x="345" y="217" fill="#a3461f" font-size="12.5" font-weight="700" text-anchor="middle">di-reset</text>

  <!-- hard -->
  <rect x="190" y="252" width="470" height="40" rx="8" fill="#f0d6c8" stroke="#a3461f" stroke-width="2" />
  <text x="36" y="277" fill="#0f1f24" font-size="13.5" font-weight="700">git reset --hard</text>
  <text x="425" y="277" fill="#a3461f" font-size="12.5" font-weight="700" text-anchor="middle">semua dibuang</text>

  <!-- Pembatas kolom -->
  <line x1="340" y1="132" x2="340" y2="292" stroke="#cfd8dc" stroke-dasharray="3 4" />
  <line x1="500" y1="132" x2="500" y2="292" stroke="#cfd8dc" stroke-dasharray="3 4" />

  <text x="36" y="320" fill="#516469" font-size="13">--soft menyimpan perubahan (tetap staged), --mixed meng-unstage, --hard membuang semua di working tree.</text>
</svg>
