<svg viewBox="0 0 760 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Diagram pemetaan port 8080 host ke port 80 di dalam container">
  <defs>
    <marker id="dpmArrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#a3461f" />
    </marker>
  </defs>
  <rect x="20" y="20" width="720" height="260" rx="20" fill="#f6fafb" stroke="#cfd8dc" />
  <text x="48" y="56" fill="#0f1f24" font-size="21" font-weight="700">Publish port: -p 8080:80</text>

  <!-- Browser -->
  <rect x="48" y="110" width="150" height="110" rx="12" fill="#ffffff" stroke="#9aa7ab" />
  <text x="70" y="152" fill="#0f1f24" font-size="16" font-weight="700">Browser</text>
  <text x="70" y="180" fill="#516469" font-size="13">localhost:8080</text>

  <!-- Host -->
  <rect x="250" y="92" width="210" height="146" rx="14" fill="#f5f9fb" stroke="#64748b" />
  <text x="270" y="122" fill="#0f1f24" font-size="15" font-weight="700">Host (laptop)</text>
  <rect x="300" y="150" width="112" height="56" rx="10" fill="#ffffff" stroke="#9aa7ab" />
  <text x="320" y="184" fill="#0f1f24" font-size="15" font-weight="700">port 8080</text>

  <!-- Container -->
  <rect x="520" y="100" width="200" height="130" rx="14" fill="#f7e7df" stroke="#a3461f" stroke-width="2" />
  <text x="544" y="130" fill="#0f1f24" font-size="15" font-weight="700">Container</text>
  <text x="544" y="150" fill="#516469" font-size="12.5">nginx</text>
  <rect x="560" y="166" width="122" height="46" rx="10" fill="#ffffff" stroke="#a3461f" />
  <text x="584" y="195" fill="#0f1f24" font-size="15" font-weight="700">port 80</text>

  <!-- Arrows -->
  <path d="M 198 165 L 248 165" fill="none" stroke="#a3461f" stroke-width="2.5" marker-end="url(#dpmArrow)" />
  <text x="206" y="156" fill="#516469" font-size="12">HTTP</text>
  <path d="M 460 165 L 518 165" fill="none" stroke="#a3461f" stroke-width="2.5" marker-end="url(#dpmArrow)" />
  <text x="468" y="150" fill="#a3461f" font-size="12.5" font-weight="700">8080 &rarr; 80</text>

  <text x="48" y="262" fill="#516469" font-size="13.5">Browser menuju port 8080 host, Docker meneruskannya ke port 80 di dalam container.</text>
</svg>
