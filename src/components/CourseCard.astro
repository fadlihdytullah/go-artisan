---
// ─────────────────────────────────────────────────────────────────────────────
// CourseCard v2 — kartu course berthumbnail ilustrasi 1:1 (flat, token-driven).
// Frame sumber: Home "Latest courses" rows (nr1kS › DRVjW) = varian horizontal,
//   dan Courses-list grid (zmpXy › yjcrs › T3uH9) = varian stacked/grid.
//
// Prop tetap KOMPATIBEL: `course` = satu entry koleksi `courses`.
// Thumbnail dari konvensi /{course.id}.png (aset di public/ root: http.png,
// openapi.png, redis.png, go-luminas.png — BUKAN /img/). href → /courses/{id}.
//
// Dua varian:
//   • "row"  (DEFAULT) — horizontal: thumb 1:1 di KIRI, body di kanan. Dipakai
//     Home "Latest courses" + halaman roadmap (kontainer .course-grid kolom).
//   • "grid" — stacked: media 1:1 di ATAS, body di bawah. Dipakai Courses-list
//     (zmpXy) bila kontainernya grid multi-kolom.
//
// Semua warna lewat var(--…) → reaktif-tema (light/reader). Flat tanpa shadow,
// sudut rounded (radius-card). UI English; SUMMARY tetap Bahasa Indonesia (dari
// frontmatter course, mengikuti teks frame). Tidak menyentuh globals.css.
// ─────────────────────────────────────────────────────────────────────────────
import Icon from './Icon.astro';

interface Props {
  course: { id: string; data: Record<string, any> };
  /** "row" (horizontal, default) | "grid" (stacked) */
  variant?: 'row' | 'grid';
}

const { course, variant = 'row' } = Astro.props as Props;
const { id, data } = course;

const href = `/luminas/${id}`;
const thumb = `/${id}.png`;
const heading = data.topTitle ?? data.title;
const badge = data.badge ?? 'COURSE';

// Meta row (frame: "N lessons" + reading time). `toc` length = jumlah bagian.
const parts = Array.isArray(data.toc) ? data.toc.length : 0;
const minutes = data.readingTime ? data.readingTime.replace(' baca', '').trim() : null;
---
<a class:list={['cc', `cc-${variant}`]} href={href}>
  <span class="cc-thumb">
    <img
      src={thumb}
      alt={`Ilustrasi course ${heading}`}
      width="320"
      height="320"
      loading="lazy"
      decoding="async"
    />
  </span>
  <span class="cc-body">
    <span class="cc-top">
      <span class="cc-badge">{badge}</span>
      {parts > 0 && <span class="cc-lessons">{parts} lessons</span>}
    </span>
    <span class="cc-title">{heading}</span>
    {data.summary && <span class="cc-sum">{data.summary}</span>}
    <span class="cc-meta">
      {minutes && <span class="cc-time">{minutes}</span>}
      {minutes && parts > 0 && <span class="cc-dot" aria-hidden="true">&middot;</span>}
      {parts > 0 && <span>{parts} bagian</span>}
      <span class="cc-link">
        <span class="cc-link-label">Open lumina</span>
        <span class="cc-chev" aria-hidden="true"><Icon name="chevron-right" size={15} /></span>
      </span>
    </span>
  </span>
</a>

<style>
  /* ── Shared (both variants) ─────────────────────────────────────────────────
     Flat parchment card, hairline border, rounded. Token-driven, theme-reactive.
     v2: fill var(--paper) #FBFAF5, stroke var(--line) #D9D4C4, radius-card. */
  .cc {
    display: flex;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    overflow: hidden; /* clip thumb ke sudut membulat */
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s ease, background-color 0.18s ease;
  }
  .cc:hover { border-color: var(--line-strong); }
  .cc:focus-visible { outline: 2px solid var(--blue-bright); outline-offset: 3px; }

  .cc-thumb {
    flex: none;
    background: var(--paper-illus); /* fallback cream hangat saat thumb lazy-load; cover image mengisi penuh */
    overflow: hidden;
    display: grid;
    place-items: center;
  }
  .cc-thumb img {
    width: 100%;
    aspect-ratio: 1 / 1; /* thumbnail TEPAT 1:1 (PNG persegi → tanpa distorsi) */
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cc-body {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    /* frame body padding 20px 22px 22px */
    padding: 20px 22px 22px;
    gap: 9px;
  }

  /* Top row: badge + lessons count (frame "Top") */
  .cc-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .cc-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--blue);          /* accent-deep #9C4A2F (AA) */
    background: var(--blue-soft); /* #F0E3D8 */
    padding: 4px 9px;
    border-radius: var(--radius-sm); /* frame cornerRadius 6 */
    line-height: 1;
    text-transform: uppercase;
  }
  .cc-lessons {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: var(--faint); /* #9A9582 */
  }

  .cc-title {
    font-family: var(--font-display); /* Fraunces */
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.012em; /* frame -0.3px @19 */
    line-height: 1.25;
    color: var(--ink);
  }

  /* Summary — Bahasa Indonesia (frame), 2-line clamp by default */
  .cc-sum {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 1.5;
    color: var(--ink-muted); /* #6E6A5C */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Meta row: reading time + parts + Open-course link/chevron */
  .cc-meta {
    margin-top: auto;
    padding-top: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: var(--faint);
  }
  .cc-dot { color: var(--line-strong); }
  .cc-link {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 600;
    color: var(--blue-bright); /* accent #BD5D3E — link cue di frame */
  }
  .cc-chev {
    display: inline-flex;
    transition: transform 0.2s ease;
  }
  .cc:hover .cc-link { color: var(--blue); }
  .cc:hover .cc-chev { transform: translateX(2px); }

  /* ── Variant: ROW (horizontal — Home "Latest courses") ──────────────────────
     Thumb 1:1 di kiri, body di kanan, konten ter-center vertikal. */
  .cc-row {
    flex-direction: row;
    align-items: stretch;
  }
  .cc-row .cc-thumb {
    width: 156px;        /* frame Thumb w156 */
    align-self: stretch;
    border-right: 1px solid var(--line); /* seam */
  }
  .cc-row .cc-thumb img { aspect-ratio: auto; } /* isi tinggi penuh kartu */
  .cc-row .cc-body {
    justify-content: center; /* frame Body justify center */
    gap: 9px;
  }
  /* Row varian kompak: ringkasan tetap 2 baris, sembunyikan meta time/parts
     agar tinggi kartu ~156 tetap rapi; link Open-course tetap tampil. */
  .cc-row .cc-meta { padding-top: 6px; }

  /* ── Variant: GRID (stacked — Courses-list zmpXy) ───────────────────────────
     Media 1:1 di atas, body di bawah; summary 3-line clamp (frame). */
  .cc-grid {
    flex-direction: column;
  }
  .cc-grid .cc-thumb {
    width: 100%;
    aspect-ratio: 1 / 1; /* media persegi penuh-lebar */
    border-bottom: 1px solid var(--line);
  }
  .cc-grid .cc-sum {
    -webkit-line-clamp: 3; /* frame summary lebih panjang */
  }

  /* ── Responsive ─────────────────────────────────────────────────────────────
     Frame mobile xSZg5 (node DZizL): kartu .cc-row TETAP horizontal — thumb 108px
     di kiri, body di kanan. JANGAN menumpuk; varian stacked adalah .cc-grid (dipakai
     /courses). Sebelumnya breakpoint ini memaksa kolom & menyimpang dari desain. */
  @media (max-width: 560px) {
    .cc-row .cc-thumb { width: 108px; }
    .cc-row .cc-body { padding: 16px 18px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cc, .cc-chev { transition: none; }
    .cc:hover .cc-chev { transform: none; }
  }
</style>
