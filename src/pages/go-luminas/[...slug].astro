---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseDetailFrame from '../../components/CourseDetailFrame.astro';
import MermaidZoom from '../../components/MermaidZoom.astro';

export async function getStaticPaths() {
  // Rute lesson dinamis: SEMUA 73 modul (termasuk go-luminas). Tidak ada
  // pengecualian go-luminas di sini — itu khusus rute courses. Urutkan menurut
  // `order` frontmatter agar konsisten dengan kurasi.
  const mods = (await getCollection('modules')).sort(
    (a, b) => a.data.order - b.data.order
  );
  const toLink = (m) =>
    m ? { id: m.id, topTitle: m.data.topTitle, badge: m.data.badge } : null;
  return mods.map((mod, i) => ({
    params: { slug: mod.id },
    props: { mod, prev: toLink(mods[i - 1]), next: toLink(mods[i + 1]) },
  }));
}

const { mod, prev, next } = Astro.props;
const { Content } = await render(mod);
const d = mod.data;
---
<BaseLayout title={d.title} nav={{ variant: 'home', readerControls: true }}>
  <CourseDetailFrame
    toc={d.toc}
    prev={prev}
    next={next}
    basePath="/go-luminas"
    moduleId={mod.id}
    articleTopPadding={true}
  >
    <Content />
  </CourseDetailFrame>

  {/* Mermaid: tombol "Perbesar" + overlay fullscreen (pan & zoom). Skrip-nya
      reusable — sumber yang sama dipakai ModuleLayout, jadi perilaku zoom
      diagram konsisten di lesson maupun course. */}
  <MermaidZoom />
</BaseLayout>
