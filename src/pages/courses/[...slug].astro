---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleTOC from '../../components/ArticleTOC.astro';
import MermaidZoom from '../../components/MermaidZoom.astro';

export async function getStaticPaths() {
  // prev/next dihitung HANYA di dalam himpunan courses, terpisah dari roadmap modules.
  // go-luminas DIKECUALIKAN: punya halaman statis khusus (courses/go-luminas.astro)
  // yang membungkus 73 modul, jadi tidak boleh dobel di rute dinamis ini.
  // aws DIKECUALIKAN juga: dilayani wrapper statis (courses/aws.astro) yang
  // membungkus 19 modul koleksi `aws`, bukan renderer mdx dinamis ini.
  const courses = (await getCollection('courses'))
    .filter((c) => c.id !== 'go-luminas' && c.id !== 'aws')
    .sort((a, b) => a.data.order - b.data.order);
  return courses.map((course, i) => {
    const toLink = (c) =>
      c ? { id: c.id, topTitle: c.data.topTitle, badge: c.data.badge } : null;
    return {
      params: { slug: course.id },
      props: {
        mod: course,
        prev: toLink(courses[i - 1]),
        next: toLink(courses[i + 1]),
        moduleIndex: i + 1,
        totalModules: courses.length,
        moduleIds: courses.map((item) => item.id),
      },
    };
  });
}

const { mod, prev, next, moduleIndex, totalModules, moduleIds } = Astro.props;
const { Content } = await render(mod);
const d = mod.data;

// Eyebrow — frame d4lirQ node bpX0n: "COURSE · OPENAPI" (mono, accent, uppercase).
// `target` di frontmatter sudah berformat "Course · OpenAPI"; pakai apa adanya
// dan upper-case lewat CSS. Fallback ke "Course · {badge}" bila target kosong.
const eyebrow = d.target ?? `Course · ${d.badge}`;

// Meta chips (frame node azTPF). Hanya `readingTime` yang tersedia sebagai data
// nyata di frontmatter; chip "Spec/Default" pada frame bersifat khusus-konten
// (placeholder) sehingga TIDAK diada-adakan. Tampilkan chip "Read" saja.
const metaChips = d.readingTime
  ? [{ key: 'Read', value: d.readingTime }]
  : [];
---
<BaseLayout title={d.title} nav={{ variant: 'home' }}>
  {/* Bordered 1180 column (continuous full-height side hairlines) — lanjut
      menerus ke footer v2 yang dirender BaseLayout di kolom .shell-col yang sama
      (SPEC §3). Body = grid 2 kolom: TOC 330 + artikel. */}
  <div class="shell-bleed">
    <div class="shell-col">
      <div class="article-layout">
        <ArticleTOC toc={d.toc} heading="On this page" />

        {/* Header DI LUAR <article> agar bisa di-reorder lewat grid-areas:
            desktop = TOC di kolom kiri sejajar header+body; mobile = header
            DULU, lalu kartu TOC, baru body (frame jW89L → U42V5Y). */}
        <header class="ca-header">
          <p class="ca-eyebrow">{eyebrow}</p>
          <h1 class="ca-title" set:html={d.topTitle} />
          <p class="ca-lede">{d.summary}</p>
          {metaChips.length > 0 && (
            <div class="ca-meta">
              {metaChips.map((chip) => (
                <span class="ca-chip">
                  <span class="ca-chip-k">{chip.key}</span>
                  <span class="ca-chip-v">{chip.value}</span>
                </span>
              ))}
            </div>
          )}
        </header>

        <article class="course-article" data-module-root data-module-id={mod.id}>
          <hr class="ca-rule" />

          <div class="ca-body">
            <Content />
          </div>
        </article>
      </div>
    </div>
  </div>

  <a href="#" id="toTop" aria-label="Kembali ke atas" title="Ke atas">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5l0 14" /><path d="M18 11l-6 -6" /><path d="M6 11l6 -6" /></svg>
  </a>

  <script is:inline>
    // Bilah "ke atas" + scroll-spy TOC (mandiri di halaman artikel ini —
    // ModuleLayout TIDAK dipakai di sini, jadi skrip-skripnya tidak ikut).
    (function () {
      // Tombol "ke atas"
      var bt = document.getElementById('toTop');
      function onScroll() {
        var top = document.documentElement.scrollTop;
        if (bt) bt.classList.toggle('show', top > 600);
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Scroll-spy: nyalakan item TOC aktif (ArticleTOC memakai data-toc-link).
      var links = document.querySelectorAll('nav.article-toc a[data-toc-link]');
      var sections = document.querySelectorAll('article.course-article section[id]');
      if (links.length && sections.length && 'IntersectionObserver' in window) {
        var obs = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                links.forEach(function (l) { l.classList.remove('active'); });
                var active = document.querySelector(
                  'nav.article-toc a[href="#' + e.target.id + '"]'
                );
                if (active) active.classList.add('active');
              }
            });
          },
          { rootMargin: '-20% 0px -70% 0px' }
        );
        sections.forEach(function (s) { obs.observe(s); });
      }
    })();
  </script>

  {/* Mermaid: tombol "Perbesar" + overlay fullscreen (pan & zoom). Skrip-nya
      reusable — sumber yang sama dipakai ModuleLayout, jadi perilaku zoom
      diagram konsisten di lesson maupun course. */}
  <MermaidZoom />
</BaseLayout>

<style>
  /* ── Article layout (frame d4lirQ → Xb3Oe) ──────────────────────────────
     Kolom 1180 berbingkai (garis sisi dari .shell-col) berisi grid 2 kolom:
     TOC 330 (ArticleTOC, garis pemisah dari border-right-nya sendiri) +
     artikel 850. Flat, rounded, token-driven (reaktif tema light + reader). */
  .article-layout {
    display: grid;
    grid-template-columns: 330px minmax(0, 1fr);
    grid-template-areas:
      "toc header"
      "toc body";
    align-items: start;
  }

  /* TOC menempati rail kiri lintas kedua baris. Di-assign dari sini karena
     .article-toc hidup di scope komponen ArticleTOC (pakai :global). */
  .article-layout :global(.article-toc) {
    grid-area: toc;
  }

  /* Header (frame ErcTr) — kini grid item tersendiri (kolom kanan, baris atas).
     Padding atas+sisi yang dulu disuplai .course-article kini di sini. */
  .ca-header {
    grid-area: header;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 56px 56px 0;
  }

  /* Artikel/body (frame vLZqx, 850w) — kolom kanan, baris bawah. */
  .course-article {
    grid-area: body;
    min-width: 0;
    padding: 0 56px 64px;
  }

  /* Eyebrow (node bpX0n) — mono 12 / 600, accent, +1.5 tracking, uppercase. */
  .ca-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--blue-bright);
  }

  /* Title (node zCVLx) — Fraunces 46 / 600, -1 tracking, line-height 1.08. */
  .ca-title {
    margin: 18px 0 0;
    font-family: var(--font-display);
    font-size: clamp(34px, 4.4vw, 46px);
    font-weight: 600;
    letter-spacing: -1px;
    line-height: 1.08;
    color: var(--ink);
  }

  /* Lede (node o9J5lW) — Inter 18 / 500, muted, line-height 1.6. */
  .ca-lede {
    margin: 22px 0 0;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.6;
    color: var(--ink-muted);
  }

  /* Meta chips (frame azTPF) — gap 12, padding-top 28. */
  .ca-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 28px 0 0;
  }
  /* Chip (frame BPg59) — card fill, hairline, radius 9, pad 9/14. */
  .ca-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 14px;
    border: 1px solid var(--line);
    border-radius: 9px;
    background: var(--paper);
  }
  .ca-chip-k {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--faint);
  }
  .ca-chip-v {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--blue);
  }

  /* Hairline antara header dan body (node IiMCF, 1px var(--line)). */
  .ca-rule {
    height: 0;
    margin: 40px 0 0;
    border: 0;
    border-top: 1px solid var(--line);
  }

  /* Body MDX — beri jarak atas; styling konten dari globals.css (Phase 1b). */
  .ca-body {
    margin-top: 40px;
  }

  /* ── Tombol "ke atas" (selaras lesson, scoped di sini) ──────────────── */
  #toTop {
    position: fixed;
    right: 24px;
    bottom: 24px;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: var(--paper);
    color: var(--ink-soft);
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease, background-color 0.15s ease;
    z-index: 40;
  }
  #toTop.show {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  #toTop:hover {
    background: var(--paper-soft);
    color: var(--ink);
  }

  /* ── Responsive: kolom tunggal dengan urutan Header → TOC (kartu) → Body
     (frame jW89L → U42V5Y, gap 28). Kartu TOC duduk DI BAWAH overview. */
  @media (max-width: 920px) {
    .article-layout {
      grid-template-columns: minmax(0, 1fr);
      grid-template-areas:
        "header"
        "toc"
        "body";
      row-gap: 28px;
    }
    .ca-header {
      padding: 40px 28px 0;
    }
    .course-article {
      padding: 0 28px 56px;
    }
    /* Jarak header→TOC→rule→body kini diatur row-gap grid; rule cukup
       menempel di atas body (gap di atasnya dari grid). */
    .ca-rule {
      margin-top: 0;
    }
    .ca-body {
      margin-top: 28px;
    }
  }
  @media (max-width: 680px) {
    .ca-header {
      padding: 36px 20px 0;
    }
    .course-article {
      padding: 0 20px 44px;
    }
    .ca-lede {
      font-size: 16px;
    }
  }
</style>
