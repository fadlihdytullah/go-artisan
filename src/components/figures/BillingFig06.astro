<svg viewBox="0 0 760 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, ui-sans-serif, system-ui, sans-serif">
  <defs>
    <marker id="bf6arr" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto" markerUnits="strokeWidth">
      <path d="M0,0 L0,6 L9,3 z" fill="#9c4a2f" />
    </marker>
  </defs>
  <text x="380" y="26" text-anchor="middle" font-size="17" fill="#241f17" font-weight="700">AWS Free Tier: akun baru vs akun lama</text>
  <text x="380" y="46" text-anchor="middle" font-size="12" fill="#6e6a5c">Kapan akun dibuat menentukan model Free Tier yang berlaku.</text>

  <rect x="290" y="62" width="180" height="46" rx="12" fill="#241f17" />
  <text x="380" y="82" text-anchor="middle" font-size="13" fill="#bd5d3e" font-weight="700">Akun dibuat kapan?</text>
  <text x="380" y="100" text-anchor="middle" font-size="11" fill="#fbfaf5">15 Juli 2025 jadi batas</text>

  <line x1="330" y1="108" x2="200" y2="140" stroke="#9c4a2f" stroke-width="2.5" marker-end="url(#bf6arr)" />
  <line x1="430" y1="108" x2="560" y2="140" stroke="#9c4a2f" stroke-width="2.5" marker-end="url(#bf6arr)" />
  <text x="230" y="132" text-anchor="middle" font-size="10" fill="#6e6a5c">&ge; 15 Jul 2025</text>
  <text x="535" y="132" text-anchor="middle" font-size="10" fill="#6e6a5c">&lt; 15 Jul 2025</text>

  <rect x="40" y="144" width="320" height="200" rx="12" fill="#f0e3d8" stroke="#9c4a2f" stroke-width="2" />
  <text x="200" y="166" text-anchor="middle" font-size="13" fill="#9c4a2f" font-weight="700">Akun BARU: model kredit</text>
  <text x="200" y="188" text-anchor="middle" font-size="11" fill="#6e6a5c">$100 saat daftar + hingga $100 dari</text>
  <text x="200" y="204" text-anchor="middle" font-size="11" fill="#6e6a5c">5 aktivitas (~$20 tiap), total s/d $200</text>

  <rect x="58" y="220" width="138" height="48" rx="8" fill="#fbfaf5" stroke="#9c4a2f" stroke-width="1.5" />
  <text x="127" y="240" text-anchor="middle" font-size="11" fill="#241f17" font-weight="700">Free plan</text>
  <text x="127" y="257" text-anchor="middle" font-size="9" fill="#6e6a5c">tak ditagih sampai upgrade</text>

  <rect x="204" y="220" width="138" height="48" rx="8" fill="#fbfaf5" stroke="#9c4a2f" stroke-width="1.5" />
  <text x="273" y="240" text-anchor="middle" font-size="11" fill="#241f17" font-weight="700">Paid plan</text>
  <text x="273" y="257" text-anchor="middle" font-size="9" fill="#6e6a5c">bayar normal sesuai pakai</text>

  <text x="200" y="290" text-anchor="middle" font-size="10" fill="#c14a39" font-weight="700">Free plan berakhir: 6 bulan ATAU kredit habis</text>
  <text x="200" y="306" text-anchor="middle" font-size="10" fill="#6e6a5c">(mana yang lebih dulu)</text>
  <text x="200" y="330" text-anchor="middle" font-size="10" fill="#6e6a5c">EC2, RDS, Lambda, Bedrock, Budgets dipakai untuk aktivitas kredit</text>

  <rect x="400" y="144" width="320" height="200" rx="12" fill="#f0e3d8" stroke="#bd5d3e" stroke-width="2" />
  <text x="560" y="166" text-anchor="middle" font-size="13" fill="#bd5d3e" font-weight="700">Akun LAMA: model klasik</text>

  <rect x="418" y="180" width="284" height="42" rx="8" fill="#fbfaf5" stroke="#bd5d3e" stroke-width="1.5" />
  <text x="560" y="199" text-anchor="middle" font-size="11" fill="#241f17" font-weight="700">12 bulan gratis</text>
  <text x="560" y="214" text-anchor="middle" font-size="9" fill="#6e6a5c">mis. 750 jam EC2 t2/t3.micro per bulan</text>

  <rect x="418" y="230" width="284" height="42" rx="8" fill="#fbfaf5" stroke="#bd5d3e" stroke-width="1.5" />
  <text x="560" y="249" text-anchor="middle" font-size="11" fill="#241f17" font-weight="700">Always free (30+ layanan)</text>
  <text x="560" y="264" text-anchor="middle" font-size="9" fill="#6e6a5c">mis. Lambda 1 jt request/bln, DynamoDB 25 GB</text>

  <rect x="418" y="280" width="284" height="42" rx="8" fill="#fbfaf5" stroke="#bd5d3e" stroke-width="1.5" />
  <text x="560" y="299" text-anchor="middle" font-size="11" fill="#241f17" font-weight="700">Trial jangka pendek</text>
  <text x="560" y="314" text-anchor="middle" font-size="9" fill="#6e6a5c">mis. uji coba beberapa layanan terbatas waktu</text>

  <rect x="40" y="360" width="680" height="60" rx="12" fill="#ece6f3" stroke="#6a5aa6" stroke-width="1.5" />
  <text x="380" y="384" text-anchor="middle" font-size="12" fill="#6a5aa6" font-weight="700">Always free tetap ada di kedua model. Pasang AWS Budgets sejak awal untuk hindari kejutan tagihan.</text>
  <text x="380" y="404" text-anchor="middle" font-size="10" fill="#6e6a5c">Jangan asumsikan aturan 12 bulan berlaku untuk akun yang dibuat setelah 15 Juli 2025.</text>
</svg>
