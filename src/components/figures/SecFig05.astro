<svg viewBox="0 0 760 440" xmlns="http://www.w3.org/2000/svg" font-family="Inter, ui-sans-serif, system-ui, sans-serif">
  <defs>
    <marker id="arrowSec05" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto" markerUnits="strokeWidth">
      <path d="M0,0 L0,6 L9,3 z" fill="#9c4a2f" />
    </marker>
    <marker id="arrowSec05o" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto" markerUnits="strokeWidth">
      <path d="M0,0 L0,6 L9,3 z" fill="#bd5d3e" />
    </marker>
  </defs>
  <rect x="16" y="16" width="728" height="408" rx="18" fill="#fbfaf5" stroke="#d9d4c4" stroke-width="2" />
  <text x="380" y="48" text-anchor="middle" font-size="20" fill="#241f17" font-weight="700">Envelope Encryption: KMS Menyimpan Kunci, Bukan Data</text>

  <rect x="60" y="80" width="180" height="44" rx="10" fill="#fbfaf5" stroke="#c6c0ac" stroke-width="2" />
  <text x="150" y="108" text-anchor="middle" font-size="14" fill="#241f17" font-weight="700">Aplikasi / Layanan</text>
  <rect x="520" y="80" width="180" height="44" rx="10" fill="#f0e3d8" stroke="#bd5d3e" stroke-width="2" />
  <text x="610" y="108" text-anchor="middle" font-size="14" fill="#241f17" font-weight="700">AWS KMS</text>
  <line x1="150" y1="124" x2="150" y2="400" stroke="#d9d4c4" stroke-width="2" />
  <line x1="610" y1="124" x2="610" y2="400" stroke="#d9d4c4" stroke-width="2" />

  <text x="380" y="158" text-anchor="middle" font-size="11" fill="#6e6a5c">1. minta data key (dicek IAM + key policy)</text>
  <line x1="150" y1="166" x2="608" y2="166" stroke="#9c4a2f" stroke-width="2" marker-end="url(#arrowSec05)" />

  <text x="380" y="196" text-anchor="middle" font-size="11" fill="#6e6a5c">2. balas: data key plaintext + data key terenkripsi</text>
  <line x1="610" y1="204" x2="152" y2="204" stroke="#bd5d3e" stroke-width="2" marker-end="url(#arrowSec05o)" />

  <rect x="60" y="226" width="540" height="70" rx="12" fill="#f0e3d8" stroke="#9c4a2f" stroke-width="2" />
  <text x="78" y="252" font-size="12" fill="#241f17" font-weight="700">3. Data key plaintext mengenkripsi objek (S3 / EBS / dll) secara lokal,</text>
  <text x="78" y="274" font-size="12" fill="#6e6a5c">lalu plaintext data key dibuang dari memori. Yang disimpan: ciphertext + data key terenkripsi.</text>

  <rect x="60" y="312" width="540" height="40" rx="10" fill="#e6f0e6" stroke="#2f7d4f" stroke-width="2" />
  <text x="78" y="337" font-size="12" fill="#2f7d4f" font-weight="700">Tersimpan bersama: ciphertext data  +  encrypted data key  (KMS key utama tetap di KMS)</text>

  <text x="380" y="382" text-anchor="middle" font-size="11" fill="#6e6a5c">4. saat baca: minta KMS dekripsi data key (gated IAM + key policy)</text>
  <line x1="150" y1="392" x2="608" y2="392" stroke="#9c4a2f" stroke-width="2" marker-end="url(#arrowSec05)" />

  <rect x="626" y="226" width="100" height="126" rx="10" fill="#f0e3d8" stroke="#bd5d3e" stroke-width="1.5" />
  <text x="676" y="252" text-anchor="middle" font-size="11" fill="#241f17" font-weight="700">KMS key</text>
  <text x="676" y="270" text-anchor="middle" font-size="9" fill="#6e6a5c">tak pernah</text>
  <text x="676" y="284" text-anchor="middle" font-size="9" fill="#6e6a5c">keluar dari</text>
  <text x="676" y="298" text-anchor="middle" font-size="9" fill="#6e6a5c">KMS;</text>
  <text x="676" y="316" text-anchor="middle" font-size="9" fill="#6e6a5c">setiap pakai</text>
  <text x="676" y="330" text-anchor="middle" font-size="9" fill="#6e6a5c">tercatat di</text>
  <text x="676" y="344" text-anchor="middle" font-size="9" fill="#6e6a5c">CloudTrail</text>
</svg>
