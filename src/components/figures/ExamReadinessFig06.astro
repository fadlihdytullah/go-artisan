<svg viewBox="0 0 760 380" xmlns="http://www.w3.org/2000/svg" font-family="Inter, ui-sans-serif, system-ui, sans-serif">
  <text x="30" y="30" text-anchor="start" font-size="15" fill="#241f17" font-weight="700">Shared Responsibility: garis tanggung jawab bergeser, tetapi tak pernah hilang</text>

  <rect x="30" y="48" width="340" height="40" rx="8" fill="#f0e3d8" stroke="#bd5d3e" stroke-width="2"/>
  <text x="200" y="73" text-anchor="middle" font-size="13" fill="#bd5d3e" font-weight="700">Customer: security IN the cloud</text>
  <rect x="390" y="48" width="340" height="40" rx="8" fill="#f0e3d8" stroke="#9c4a2f" stroke-width="2"/>
  <text x="560" y="73" text-anchor="middle" font-size="13" fill="#9c4a2f" font-weight="700">AWS: security OF the cloud</text>

  <text x="30" y="118" text-anchor="start" font-size="12" fill="#6e6a5c" font-weight="700">Makin ke kanan (serverless), makin banyak yang ditangani AWS. Tapi 3 hal ini selalu milik customer:</text>

  <rect x="30" y="132" width="350" height="120" rx="10" fill="#f0e3d8" stroke="#bd5d3e" stroke-width="2"/>
  <text x="48" y="156" text-anchor="start" font-size="12" fill="#bd5d3e" font-weight="700">Selalu tanggung jawab customer</text>
  <text x="48" y="180" text-anchor="start" font-size="11" fill="#241f17">1. Data (klasifikasi, enkripsi, backup)</text>
  <text x="48" y="202" text-anchor="start" font-size="11" fill="#241f17">2. Akses &amp; identitas (IAM, MFA, least privilege)</text>
  <text x="48" y="224" text-anchor="start" font-size="11" fill="#241f17">3. Konfigurasi (bucket policy, security group)</text>
  <text x="48" y="244" text-anchor="start" font-size="10" fill="#6e6a5c">Managed service tidak memindahkan ketiganya ke AWS.</text>

  <rect x="400" y="132" width="330" height="120" rx="10" fill="#fbfaf5" stroke="#d9d4c4" stroke-width="2"/>
  <text x="418" y="156" text-anchor="start" font-size="12" fill="#9c4a2f" font-weight="700">Selalu tanggung jawab AWS</text>
  <text x="418" y="180" text-anchor="start" font-size="11" fill="#241f17">&bull; Data center fisik, listrik, jaringan inti</text>
  <text x="418" y="202" text-anchor="start" font-size="11" fill="#241f17">&bull; Hardware host dan hypervisor</text>
  <text x="418" y="224" text-anchor="start" font-size="11" fill="#241f17">&bull; Patching platform pada managed service</text>
  <text x="418" y="244" text-anchor="start" font-size="10" fill="#6e6a5c">Customer tetap tak bisa mengaksesnya langsung.</text>

  <text x="30" y="288" text-anchor="start" font-size="12" fill="#6e6a5c" font-weight="700">Slider: porsi customer mengecil dari kiri ke kanan</text>

  <rect x="30" y="300" width="700" height="34" rx="8" fill="#f0e3d8"/>
  <rect x="30" y="300" width="490" height="34" rx="8" fill="#bd5d3e"/>
  <text x="150" y="322" text-anchor="middle" font-size="11" fill="#fbfaf5" font-weight="700">IaaS (EC2): customer urus OS, patch, app</text>
  <text x="635" y="322" text-anchor="middle" font-size="11" fill="#241f17" font-weight="700">AWS</text>

  <line x1="30" y1="346" x2="30" y2="356" stroke="#c6c0ac" stroke-width="1.5"/>
  <text x="30" y="370" text-anchor="start" font-size="10" fill="#6e6a5c">IaaS: EC2</text>
  <line x1="380" y1="346" x2="380" y2="356" stroke="#c6c0ac" stroke-width="1.5"/>
  <text x="380" y="370" text-anchor="middle" font-size="10" fill="#6e6a5c">Managed: RDS</text>
  <line x1="730" y1="346" x2="730" y2="356" stroke="#c6c0ac" stroke-width="1.5"/>
  <text x="730" y="370" text-anchor="end" font-size="10" fill="#6e6a5c">Serverless: Lambda, S3, DynamoDB</text>
</svg>
