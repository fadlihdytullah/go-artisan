---
import '../styles/globals.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface NavProps {
  variant: 'home' | 'module';
  badge?: string;
  siteName?: string;
  moduleTitle?: string;
  moduleSub?: string;
  summaryHref?: string;
  fontControls?: boolean;
  toc?: boolean;
}
interface Props {
  title: string;
  nav: NavProps;
  /** Sembunyikan footer v2 (mis. layar penuh tanpa chrome). Default: tampil. */
  hideFooter?: boolean;
}
const { title, nav, hideFooter = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400;1,9..144,500&family=Inter:wght@400;450;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  {/* Cegah FOUC: terapkan tema & skala sebelum render — di SEMUA halaman */}
  <script is:inline>
    (function () {
      try {
        var r = document.documentElement;
        var t = localStorage.getItem('reader-theme');
        // Migrasi nilai lama: sepia→reader, dark→light, nilai asing→light.
        if (t === 'sepia') t = 'reader';
        if (t === 'dark' || (t !== 'light' && t !== 'reader')) t = 'light';
        r.setAttribute('data-theme', t);
        var s = localStorage.getItem('reader-scale');
        if (s) r.style.setProperty('--scale', s);
      } catch (e) {}
    })();
  </script>
  <script is:inline>
    // Simpan progres belajar per browser agar homepage dan halaman modul bisa sinkron.
    (function () {
      var KEY = 'go-artisan-progress-v1';

      function readState() {
        try {
          var raw = localStorage.getItem(KEY);
          if (!raw) return { completed: {}, lastVisited: null, updatedAt: null };
          var parsed = JSON.parse(raw);
          return {
            completed: parsed && typeof parsed.completed === 'object' && parsed.completed ? parsed.completed : {},
            lastVisited: parsed && typeof parsed.lastVisited === 'string' ? parsed.lastVisited : null,
            updatedAt: parsed && typeof parsed.updatedAt === 'string' ? parsed.updatedAt : null,
          };
        } catch (e) {
          return { completed: {}, lastVisited: null, updatedAt: null };
        }
      }

      function writeState(state) {
        state.updatedAt = new Date().toISOString();
        try {
          localStorage.setItem(KEY, JSON.stringify(state));
        } catch (e) {}
        window.dispatchEvent(new CustomEvent('module-progress:change', { detail: state }));
        return state;
      }

      window.moduleProgress = {
        getState: function () {
          return readState();
        },
        isCompleted: function (moduleId) {
          var state = readState();
          return !!state.completed[moduleId];
        },
        setCompleted: function (moduleId, value) {
          var state = readState();
          if (value) state.completed[moduleId] = true;
          else delete state.completed[moduleId];
          return writeState(state);
        },
        setLastVisited: function (moduleId) {
          var state = readState();
          state.lastVisited = moduleId;
          return writeState(state);
        },
        getCompletedCount: function (moduleIds) {
          var state = readState();
          return moduleIds.filter(function (moduleId) {
            return !!state.completed[moduleId];
          }).length;
        },
        getCompletionRatio: function (moduleIds) {
          if (!moduleIds || !moduleIds.length) return 0;
          return this.getCompletedCount(moduleIds) / moduleIds.length;
        },
        getNextModuleId: function (moduleIds) {
          var state = readState();
          for (var i = 0; i < moduleIds.length; i++) {
            if (!state.completed[moduleIds[i]]) return moduleIds[i];
          }
          if (state.lastVisited && moduleIds.indexOf(state.lastVisited) !== -1) {
            return state.lastVisited;
          }
          return moduleIds[0] || null;
        },
      };
    })();
  </script>
</head>
<body>
  <Navbar {...nav} />

  <slot />

  {!hideFooter && (
    <div class="shell-bleed shell-footer-wrap">
      <div class="shell-col">
        <footer class="shell-footer">
          <Footer />
        </footer>
      </div>
    </div>
  )}

  <script is:inline>
    // Kontrol baca: toggle tema (light ⇄ reader) + ukuran font. Aktif di semua halaman.
    (function () {
      var root = document.documentElement;
      var THEMES = ['light', 'reader'];
      // Tabler Icons (MIT) — bagian dalam SVG per tema baca.
      var ICON = {
        light: '<path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" /><path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7" />',
        reader: '<path d="M3 19a9 9 0 0 1 9 0a9 9 0 0 1 9 0" /><path d="M3 6a9 9 0 0 1 9 0a9 9 0 0 1 9 0" /><path d="M3 6l0 13" /><path d="M12 6l0 13" /><path d="M21 6l0 13" />',
      };
      function iconSvg(inner) {
        return '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + inner + '</svg>';
      }
      var MIN = 0.85, MAX = 1.3, STEP = 0.1;
      var scale = parseFloat(localStorage.getItem('reader-scale')) || 1;

      function setTheme(t) {
        root.setAttribute('data-theme', t);
        try { localStorage.setItem('reader-theme', t); } catch (e) {}
        document.querySelectorAll('[data-theme-toggle] .ti').forEach(function (el) {
          el.innerHTML = iconSvg(ICON[t]);
        });
      }
      function setScale(s) {
        scale = Math.min(MAX, Math.max(MIN, Math.round(s * 100) / 100));
        root.style.setProperty('--scale', scale);
        try { localStorage.setItem('reader-scale', scale); } catch (e) {}
      }

      // Sanitasi nilai awal (atribut/localStorage lama) sebelum init:
      // sepia→reader, dark→light, nilai asing→light.
      var initial = root.getAttribute('data-theme');
      if (initial === 'sepia') initial = 'reader';
      if (THEMES.indexOf(initial) === -1) initial = 'light';
      setTheme(initial);
      setScale(scale);

      document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var i = THEMES.indexOf(root.getAttribute('data-theme'));
          setTheme(THEMES[(i + 1) % THEMES.length]);
        });
      });
      document.querySelectorAll('[data-font="inc"]').forEach(function (b) {
        b.addEventListener('click', function () { setScale(scale + STEP); });
      });
      document.querySelectorAll('[data-font="dec"]').forEach(function (b) {
        b.addEventListener('click', function () { setScale(scale - STEP); });
      });
    })();
  </script>
  <script is:inline>
    // Sinkronkan semua bilah progres belajar dari state lokal yang sama.
    (function () {
      var api = window.moduleProgress;
      var blocks = Array.prototype.slice.call(document.querySelectorAll('[data-learning-progress]'));
      if (!api || !blocks.length) return;

      function parseIds(node) {
        try {
          return JSON.parse(node.getAttribute('data-module-ids') || '[]');
        } catch (e) {
          return [];
        }
      }

      function syncBlock(block) {
        var moduleIds = parseIds(block);
        if (!moduleIds.length) return;

        var completedCount = api.getCompletedCount(moduleIds);
        var totalCount = moduleIds.length;
        var ratio = api.getCompletionRatio(moduleIds);
        var percent = Math.round(ratio * 100);
        var nextId = api.getNextModuleId(moduleIds);
        var currentModuleId = block.getAttribute('data-current-module-id') || '';
        var currentModuleIndex = Number(block.getAttribute('data-current-module-index') || '0');
        var currentDone = currentModuleId ? api.isCompleted(currentModuleId) : false;
        var copy = block.querySelector('[data-learning-progress-copy]');
        var value = block.querySelector('[data-learning-progress-value]');
        var count = block.querySelector('[data-learning-progress-count]');
        var fill = block.querySelector('[data-learning-progress-fill]');
        var meter = block.querySelector('[data-learning-progress-meter]');

        if (value) value.textContent = percent + '%';
        if (count) count.textContent = completedCount + '/' + totalCount + ' modul selesai';
        if (fill) fill.style.transform = 'scaleX(' + ratio.toFixed(4) + ')';
        if (meter) {
          meter.setAttribute('aria-valuenow', String(completedCount));
          meter.setAttribute('aria-valuetext', completedCount + ' dari ' + totalCount + ' modul selesai');
        }

        if (!copy) return;
        if (completedCount === totalCount) {
          copy.textContent = 'Semua modul sudah selesai di browser ini. Kamu bisa review kapan saja dari roadmap atau switcher modul.';
          return;
        }
        if (currentModuleId) {
          if (currentDone) {
            copy.textContent = 'Modul ini sudah selesai. Lanjutkan ke modul berikutnya atau review bagian yang masih ingin diperdalam.';
          } else if (completedCount > 0) {
            copy.textContent = 'Kamu sedang di modul ' + currentModuleIndex + '. Setelah selesai, tandai modul ini agar progres kursus tetap rapi.';
          } else {
            copy.textContent = 'Ini modul awal perjalananmu. Tandai selesai saat kamu menuntaskan materi agar roadmap berikutnya terbuka lebih jelas.';
          }
          return;
        }
        if (completedCount > 0) {
          copy.textContent = completedCount + ' dari ' + totalCount + ' modul sudah selesai. Lanjutkan dari ' + nextId + ' atau lompat ke topik yang sedang kamu butuhkan.';
        } else {
          copy.textContent = 'Belum ada progres tersimpan. Mulai dari modul pertama atau masuk ke topik yang paling relevan untuk kerja backend-mu sekarang.';
        }
      }

      function syncAll() {
        blocks.forEach(syncBlock);
      }

      syncAll();
      window.addEventListener('module-progress:change', syncAll);
    })();
  </script>
</body>
</html>
