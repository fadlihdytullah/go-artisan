<svg viewBox="0 0 760 420" xmlns="http://www.w3.org/2000/svg" font-family="Inter, ui-sans-serif, system-ui, sans-serif">
  <defs>
    <marker id="er5arrow" markerWidth="9" markerHeight="9" refX="7" refY="3" orient="auto">
      <path d="M0,0 L7,3 L0,6 Z" fill="#9c4a2f"/>
    </marker>
  </defs>

  <text x="30" y="30" text-anchor="start" font-size="15" fill="#241f17" font-weight="700">Logistik hari-H: dua jalur ujian dan strategi waktu</text>

  <rect x="30" y="48" width="700" height="120" rx="12" fill="#f0e3d8" stroke="#9c4a2f" stroke-width="2"/>
  <text x="48" y="72" text-anchor="start" font-size="13" fill="#9c4a2f" font-weight="700">Jalur A &middot; Pearson VUE test center</text>
  <text x="48" y="96" text-anchor="start" font-size="11" fill="#6e6a5c">&bull; Datang lebih awal, bawa dua ID resmi (salah satunya foto, nama persis sama dgn akun).</text>
  <text x="48" y="116" text-anchor="start" font-size="11" fill="#6e6a5c">&bull; Barang dititip di loker, tidak boleh bawa HP/catatan ke ruang ujian.</text>
  <text x="48" y="136" text-anchor="start" font-size="11" fill="#6e6a5c">&bull; Pengawas (proctor) hadir di lokasi, komputer dan ruangan disediakan.</text>
  <text x="48" y="156" text-anchor="start" font-size="11" fill="#6e6a5c">&bull; Cocok bila koneksi internet rumah tidak stabil atau ingin lingkungan netral.</text>

  <rect x="30" y="180" width="700" height="140" rx="12" fill="#f0e3d8" stroke="#bd5d3e" stroke-width="2"/>
  <text x="48" y="204" text-anchor="start" font-size="13" fill="#bd5d3e" font-weight="700">Jalur B &middot; Online proctored (OnVUE)</text>
  <text x="48" y="228" text-anchor="start" font-size="11" fill="#6e6a5c">&bull; Jalankan system check (kamera, mikrofon, jaringan) jauh-jauh hari sebelum jadwal.</text>
  <text x="48" y="248" text-anchor="start" font-size="11" fill="#6e6a5c">&bull; Ruangan bersih dan sendirian: tanpa orang lain, tanpa catatan, tanpa kabel earphone.</text>
  <text x="48" y="268" text-anchor="start" font-size="11" fill="#6e6a5c">&bull; Check-in 30 menit sebelum: foto ID + foto wajah + sapuan ruangan via webcam.</text>
  <text x="48" y="288" text-anchor="start" font-size="11" fill="#6e6a5c">&bull; Tidak boleh bicara, menengok keluar layar, atau meninggalkan kursi tanpa izin.</text>
  <text x="48" y="308" text-anchor="start" font-size="11" fill="#6e6a5c">&bull; Pass/fail muncul di layar setelah selesai; skor detail per-domain menyusul di email.</text>

  <rect x="30" y="332" width="700" height="72" rx="12" fill="#ece6f3" stroke="#6a5aa6" stroke-width="2"/>
  <text x="48" y="354" text-anchor="start" font-size="13" fill="#6a5aa6" font-weight="700">Strategi waktu &middot; 90 menit untuk 65 soal</text>
  <rect x="48" y="364" width="150" height="30" rx="6" fill="#fbfaf5" stroke="#6a5aa6" stroke-width="1.5"/>
  <text x="123" y="383" text-anchor="middle" font-size="10" fill="#241f17" font-weight="700">Pass 1: jawab cepat</text>
  <line x1="198" y1="379" x2="226" y2="379" stroke="#9c4a2f" stroke-width="2" marker-end="url(#er5arrow)"/>
  <rect x="232" y="364" width="150" height="30" rx="6" fill="#fbfaf5" stroke="#6a5aa6" stroke-width="1.5"/>
  <text x="307" y="383" text-anchor="middle" font-size="10" fill="#241f17" font-weight="700">Flag yang ragu</text>
  <line x1="382" y1="379" x2="410" y2="379" stroke="#9c4a2f" stroke-width="2" marker-end="url(#er5arrow)"/>
  <rect x="416" y="364" width="150" height="30" rx="6" fill="#fbfaf5" stroke="#6a5aa6" stroke-width="1.5"/>
  <text x="491" y="383" text-anchor="middle" font-size="10" fill="#241f17" font-weight="700">Pass 2: review flag</text>
  <line x1="566" y1="379" x2="594" y2="379" stroke="#9c4a2f" stroke-width="2" marker-end="url(#er5arrow)"/>
  <rect x="600" y="364" width="118" height="30" rx="6" fill="#f0e3d8" stroke="#bd5d3e" stroke-width="1.5"/>
  <text x="659" y="383" text-anchor="middle" font-size="10" fill="#241f17" font-weight="700">Jangan kosongkan</text>
</svg>
