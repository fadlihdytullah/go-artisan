<svg viewBox="0 0 760 430" xmlns="http://www.w3.org/2000/svg" font-family="Inter, ui-sans-serif, system-ui, sans-serif">
  <text x="380" y="26" text-anchor="middle" font-size="14" fill="#6e6a5c">Tiap baris menunjukkan porsi traffic ke versi lama (gelap) dan versi baru (oranye) seiring waktu.</text>
  <line x1="200" y1="44" x2="730" y2="44" stroke="#d9d4c4" stroke-width="1.5" />
  <text x="200" y="40" text-anchor="start" font-size="11" fill="#6e6a5c">awal</text>
  <text x="730" y="40" text-anchor="end" font-size="11" fill="#6e6a5c">selesai</text>

  <text x="22" y="86" text-anchor="start" font-size="14" fill="#241f17" font-weight="700">In-place</text>
  <text x="22" y="104" text-anchor="start" font-size="10" fill="#6e6a5c">ganti di tempat</text>
  <rect x="200" y="64" width="160" height="40" rx="8" fill="#241f17" />
  <text x="280" y="89" text-anchor="middle" font-size="11" fill="#fbfaf5" font-weight="700">v-lama</text>
  <rect x="380" y="64" width="160" height="40" rx="8" fill="#c6c0ac" />
  <text x="460" y="89" text-anchor="middle" font-size="11" fill="#fbfaf5" font-weight="700">downtime</text>
  <rect x="560" y="64" width="160" height="40" rx="8" fill="#bd5d3e" />
  <text x="640" y="89" text-anchor="middle" font-size="11" fill="#fbfaf5" font-weight="700">v-baru</text>

  <text x="22" y="166" text-anchor="start" font-size="14" fill="#241f17" font-weight="700">Rolling</text>
  <text x="22" y="184" text-anchor="start" font-size="10" fill="#6e6a5c">bertahap per batch</text>
  <rect x="200" y="144" width="130" height="40" rx="8" fill="#241f17" />
  <text x="265" y="169" text-anchor="middle" font-size="11" fill="#fbfaf5" font-weight="700">lama 100%</text>
  <rect x="338" y="144" width="100" height="40" rx="8" fill="#241f17" />
  <text x="388" y="169" text-anchor="middle" font-size="10" fill="#fbfaf5" font-weight="700">lama</text>
  <rect x="446" y="144" width="100" height="40" rx="8" fill="#bd5d3e" />
  <text x="496" y="169" text-anchor="middle" font-size="10" fill="#fbfaf5" font-weight="700">baru</text>
  <rect x="554" y="144" width="166" height="40" rx="8" fill="#bd5d3e" />
  <text x="637" y="169" text-anchor="middle" font-size="11" fill="#fbfaf5" font-weight="700">baru 100%</text>

  <text x="22" y="246" text-anchor="start" font-size="14" fill="#241f17" font-weight="700">Blue/Green</text>
  <text x="22" y="264" text-anchor="start" font-size="10" fill="#6e6a5c">tukar penuh</text>
  <rect x="200" y="224" width="300" height="40" rx="8" fill="#241f17" />
  <text x="350" y="249" text-anchor="middle" font-size="11" fill="#fbfaf5" font-weight="700">blue (lama) 100%</text>
  <rect x="520" y="224" width="200" height="40" rx="8" fill="#bd5d3e" />
  <text x="620" y="249" text-anchor="middle" font-size="11" fill="#fbfaf5" font-weight="700">green (baru) 100%</text>
  <line x1="510" y1="216" x2="510" y2="272" stroke="#9c4a2f" stroke-width="2.5" stroke-dasharray="5 4" />
  <text x="510" y="288" text-anchor="middle" font-size="10" fill="#9c4a2f" font-weight="700">cutover</text>

  <text x="22" y="346" text-anchor="start" font-size="14" fill="#241f17" font-weight="700">Canary</text>
  <text x="22" y="364" text-anchor="start" font-size="10" fill="#6e6a5c">naik bertahap</text>
  <rect x="200" y="324" width="280" height="40" rx="8" fill="#241f17" />
  <text x="340" y="349" text-anchor="middle" font-size="11" fill="#fbfaf5" font-weight="700">lama 90%</text>
  <rect x="488" y="324" width="58" height="40" rx="8" fill="#bd5d3e" />
  <text x="517" y="349" text-anchor="middle" font-size="10" fill="#fbfaf5" font-weight="700">10%</text>
  <rect x="554" y="324" width="80" height="40" rx="8" fill="#241f17" />
  <text x="594" y="349" text-anchor="middle" font-size="10" fill="#fbfaf5" font-weight="700">50%</text>
  <rect x="642" y="324" width="78" height="40" rx="8" fill="#bd5d3e" />
  <text x="681" y="349" text-anchor="middle" font-size="10" fill="#fbfaf5" font-weight="700">100%</text>

  <rect x="200" y="392" width="22" height="16" rx="4" fill="#241f17" />
  <text x="230" y="405" text-anchor="start" font-size="12" fill="#6e6a5c">versi lama</text>
  <rect x="330" y="392" width="22" height="16" rx="4" fill="#bd5d3e" />
  <text x="360" y="405" text-anchor="start" font-size="12" fill="#6e6a5c">versi baru</text>
  <rect x="460" y="392" width="22" height="16" rx="4" fill="#c6c0ac" />
  <text x="490" y="405" text-anchor="start" font-size="12" fill="#6e6a5c">jeda atau downtime singkat</text>
</svg>
