---
// Kartu Course berthumbnail ilustrasi (flat, token-driven).
// Menerima satu entry koleksi `courses`. Thumbnail dari konvensi /{course.id}.png
// (aset di public/ root: http.png, openapi.png, redis.png — BUKAN /img/).
// Semua warna lewat var(--…) agar reaktif-tema (light/reader). Flat tanpa shadow,
// sudut rounded (radius-card). Seluruh kartu adalah <a> (klikabel penuh) → /courses/{id}.
import Icon from './Icon.astro';

const { course } = Astro.props;
const { id, data } = course;

const href = `/courses/${id}`;
const thumb = `/${id}.png`;
const heading = data.topTitle ?? data.title;
const minutes = data.readingTime ? data.readingTime.replace(' baca', '') : null;
const parts = Array.isArray(data.toc) ? data.toc.length : 0;
---
<a class="course-card" href={href}>
  <span class="course-card-thumb">
    <img
      src={thumb}
      alt={`Ilustrasi course ${heading}`}
      width="240"
      height="240"
      loading="lazy"
      decoding="async"
    />
  </span>
  <span class="course-card-body">
    {data.badge && <span class="course-card-badge">{data.badge}</span>}
    <span class="course-card-title">{heading}</span>
    {data.summary && <span class="course-card-sum">{data.summary}</span>}
    <span class="course-card-meta">
      {minutes && <span>{minutes}</span>}
      {minutes && parts > 0 && <span class="dotsep" aria-hidden="true">&middot;</span>}
      {parts > 0 && <span>{parts} bagian</span>}
      <span class="course-card-go" aria-hidden="true"><Icon name="chevron-right" size={16} /></span>
    </span>
  </span>
</a>

<style>
  /* ── Course card kompak: thumbnail ilustrasi (persegi) di KIRI, teks di kanan ──
     PNG persegi 1254x1254 → thumb persegi, nyaris tanpa crop. Sumber tunggal layout
     kartu (globals.css hanya pegang kontainer .course-grid). Token-driven,
     reaktif tema light/reader. Flat tanpa shadow, sudut rounded (radius-card). */
  .course-card {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    border: 1px solid color-mix(in srgb, var(--ink) 10%, transparent);
    border-radius: var(--radius-card);
    overflow: hidden; /* anak ikut ter-clip ke sudut membulat */
    background: var(--paper);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s ease, transform 0.22s var(--ease-spring), background-color 0.18s ease;
  }
  .course-card:hover {
    border-color: color-mix(in srgb, var(--blue) 28%, transparent);
    transform: translateY(-2px);
    background: color-mix(in srgb, var(--blue-soft) 30%, var(--paper));
  }
  .course-card:focus-visible { outline: 2px solid var(--blue-bright); outline-offset: 3px; }

  .course-card-thumb {
    flex: 0 0 120px;
    align-self: stretch;
    background: var(--lav); /* fallback latar; cover image mengisi penuh, tema-invariant */
    border-right: 1px solid var(--hair); /* seam netral (ink 9%) cocok untuk semua tint PNG */
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .course-card-thumb img {
    width: 100%;
    aspect-ratio: 1 / 1; /* thumbnail TEPAT 1:1 (persegi) */
    height: auto;
    object-fit: cover; /* PNG persegi → tanpa distorsi/crop */
    display: block;
  }

  .course-card-body {
    flex: 1 1 auto;
    min-width: 0;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .course-card-badge {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--blue);
    background: var(--blue-soft);
    padding: 2px 7px;
    border-radius: var(--radius-xs);
    align-self: flex-start;
  }
  .course-card-title {
    font-size: 16px;
    font-weight: 720;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--ink);
  }
  .course-card-sum {
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--ink-soft);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .course-card-meta {
    margin-top: auto;
    padding-top: 4px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--ink-muted);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .course-card-meta .dotsep { color: var(--line-strong); }
  .course-card-go {
    color: var(--blue);
    display: inline-flex;
    margin-left: auto;
    transition: color 0.18s ease, transform 0.2s ease;
  }
  .course-card:hover .course-card-go { color: var(--blue-bright); transform: translateX(2px); }

  @media (max-width: 560px) {
    .course-card-thumb { flex-basis: 96px; }
    .course-card-body { padding: 12px 13px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .course-card:hover { transform: none; }
    .course-card:hover .course-card-go { transform: none; }
  }
</style>
