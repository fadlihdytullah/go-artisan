---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import CourseHero from '../../components/course/CourseHero.astro';

// Go Luminas = course unggulan "Tracks" varian PHASES: membungkus SELURUH 73
// modul backend (koleksi `modules`, R1..R9) sebagai 9 tahap accordion yang
// menautkan tiap modul ke /lessons/<slug>. Hero + styling dibagi dengan AWS
// lewat CourseHero + kelas .track-* di globals.css (satu sumber, anti-drift).
const course = await getEntry('luminas', 'go-luminas');
const cd = course.data;

const mods = (await getCollection('modules')).sort(
  (a, b) => a.data.order - b.data.order
);
const moduleIds = mods.map((mod) => mod.id);

// Kelompokkan modul per roadmap/tahap (r1c01 -> tahap 1, r2c03 -> tahap 2, dst.).
type RoadmapGroup = { num: number; name: string; modules: typeof mods };
const roadmapMap = new Map<number, RoadmapGroup>();
for (const mod of mods) {
  const idMatch = mod.id.match(/^r(\d+)/);
  const roadmapNum = idMatch ? parseInt(idMatch[1]) : 99;
  const targetParts = mod.data.target?.split('·') ?? [];
  const roadmapName = targetParts[1]?.trim() ?? `Roadmap ${roadmapNum}`;
  if (!roadmapMap.has(roadmapNum)) {
    roadmapMap.set(roadmapNum, { num: roadmapNum, name: roadmapName, modules: [] });
  }
  roadmapMap.get(roadmapNum)!.modules.push(mod);
}
const roadmaps = Array.from(roadmapMap.values()).sort((a, b) => a.num - b.num);
---
<BaseLayout title={cd.title} nav={{ variant: 'home' }}>
  {/* Kolom 1180 berbingkai membungkus hero + kurikulum: garis sisi vertikal
      (dari .shell-col) + garis horizontal atas/bawah hero (border-top band +
      divider antar-band) — hero "berbingkai" sesuai frame XM9X0. */}
  <main class="course-detail" data-home-progress data-module-ids={JSON.stringify(moduleIds)}>
    <div class="shell-col">
      <section class="shell-band course-hero-band">
        <CourseHero
          eyebrow={cd.target ?? 'Course · Go Luminas'}
          title={cd.topTitle ?? cd.title}
          sub={cd.topSub}
          lede={cd.summary}
          facts={`${mods.length} modul · ${roadmaps.length} tahap`}
          image="/go-luminas.png"
          primaryHref={`/lessons/${mods[0]?.id ?? ''}`}
          adaptiveProgress={true}
        />
      </section>

      <section class="shell-band course-cur" id="kurikulum">
        <header class="course-cur-head">
          <h2 class="course-cur-title">Kurikulum</h2>
          <span class="course-cur-count">{mods.length} modul tersedia</span>
        </header>

        <div class="track-phases">
          {roadmaps.map((roadmap) => (
            <details
              class="track-phase"
              id={`roadmap-${roadmap.num}`}
              open={roadmap.num === 1}
              data-roadmap-group={roadmap.num}
            >
              <summary class="track-phase-head">
                <span class="track-phase-lead">
                  <span class="track-phase-tag">Tahap {roadmap.num}</span>
                  <span class="track-phase-name">{roadmap.name}</span>
                </span>
                <span class="track-phase-meta">
                  <span class="track-phase-progress" data-roadmap-progress hidden></span>
                  <span class="track-phase-total">{roadmap.modules.length} modul</span>
                  <span class="track-phase-chevron" aria-hidden="true"><Icon name="chevron-down" size={18} /></span>
                </span>
              </summary>

              <ol class="track-modules">
                {roadmap.modules.map((mod, localIdx) => (
                  <li class="track-module" style={`--i:${localIdx}`} data-module-item data-module-id={mod.id}>
                    <a href={`/lessons/${mod.id}`} class="track-module-link" data-module-link>
                      <span class="track-module-ico" aria-hidden="true">
                        {/* circle (todo) */}
                        <svg class="ico-todo" viewBox="0 0 24 24" width="18" height="18" fill="none"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
                        </svg>
                        {/* circle-dot (current) */}
                        <svg class="ico-current" viewBox="0 0 24 24" width="18" height="18" fill="none"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
                          <path d="M12 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" />
                        </svg>
                        {/* circle-check (done) */}
                        <svg class="ico-done" viewBox="0 0 24 24" width="18" height="18" fill="none"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
                          <path d="M9 12l2 2l4 -4" />
                        </svg>
                      </span>
                      <span class="track-module-title">
                        {mod.data.topTitle}
                        {mod.data.order === 1 && <span class="track-module-flag">Mulai di sini</span>}
                        <span class="track-module-state" data-module-state hidden>Belum mulai</span>
                      </span>
                      <span class="track-module-meta">
                        {mod.data.readingTime
                          ? mod.data.readingTime.replace(' baca', '').replace('menit', 'min')
                          : `${mod.data.toc.length} bagian`}
                      </span>
                    </a>
                  </li>
                ))}
              </ol>
            </details>
          ))}
        </div>
      </section>
    </div>
  </main>

  <script is:inline>
    // Membaca progres lokal untuk CTA "Continue learning" dan status tiap modul.
    (function () {
      var api = window.moduleProgress;
      var root = document.querySelector('[data-home-progress]');
      var moduleIds = [];
      var continueLink = document.querySelector('[data-continue-link]');
      var continueLabel = document.querySelector('[data-continue-label]');
      try {
        moduleIds = root ? JSON.parse(root.getAttribute('data-module-ids') || '[]') : [];
      } catch (e) {
        moduleIds = [];
      }
      if (!api || !continueLink || !continueLabel || !moduleIds.length) return;

      function sync() {
        var state = api.getState();
        var completedCount = api.getCompletedCount(moduleIds);
        var nextId = api.getNextModuleId(moduleIds);
        var allDone = completedCount === moduleIds.length;

        continueLink.setAttribute('href', '/lessons/' + nextId);
        continueLabel.textContent = allDone ? 'Review course' : completedCount > 0 ? 'Continue learning' : 'Start learning';

        document.querySelectorAll('[data-module-item]').forEach(function (item) {
          var moduleId = item.getAttribute('data-module-id');
          var stateTag = item.querySelector('[data-module-state]');
          var link = item.querySelector('[data-module-link]');
          if (!moduleId || !stateTag || !link) return;

          var isCompleted = !!state.completed[moduleId];
          var isNext = !isCompleted && moduleId === nextId && !allDone;

          item.classList.toggle('is-complete', isCompleted);
          item.classList.toggle('is-next', isNext);

          if (isCompleted) {
            stateTag.hidden = false;
            stateTag.textContent = 'Selesai';
          } else if (isNext) {
            stateTag.hidden = false;
            stateTag.textContent = 'Lanjut di sini';
          } else {
            stateTag.hidden = true;
            stateTag.textContent = 'Belum mulai';
          }
        });

        // Ringkasan progres per tahap di header accordion (mis. "3/12 selesai").
        document.querySelectorAll('[data-roadmap-group]').forEach(function (group) {
          var items = group.querySelectorAll('[data-module-item]');
          var progressTag = group.querySelector('[data-roadmap-progress]');
          if (!progressTag || !items.length) return;
          var done = 0;
          items.forEach(function (item) {
            if (state.completed[item.getAttribute('data-module-id')]) done++;
          });
          group.classList.toggle('is-complete', done === items.length);
          if (done > 0) {
            progressTag.hidden = false;
            progressTag.textContent = done === items.length
              ? '✓ selesai'
              : done + '/' + items.length + ' selesai';
          } else {
            progressTag.hidden = true;
            progressTag.textContent = '';
          }
        });

        return nextId;
      }

      // Buka accordion tahap yang memuat sebuah modul (mis. modul "lanjut").
      function openRoadmapOf(moduleId) {
        if (!moduleId) return;
        var item = document.querySelector('[data-module-item][data-module-id="' + moduleId + '"]');
        var group = item && item.closest('[data-roadmap-group]');
        if (group && !group.open) group.open = true;
      }

      var nextId = sync();

      if (api.getCompletedCount(moduleIds) > 0) openRoadmapOf(nextId);

      window.addEventListener('module-progress:change', sync);
    })();
  </script>
</BaseLayout>
