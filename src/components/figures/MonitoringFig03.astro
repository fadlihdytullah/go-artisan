  <text x="380" y="294" text-anchor="middle" font-size="11" fill="#6e6a5c">Jejak siapa &amp; kapan</text>
  <rect x="294" y="314" width="172" height="34" rx="9" fill="#fbfaf5" stroke="#0a7d6e" stroke-width="1.5" />
  <text x="380" y="336" text-anchor="middle" font-size="11" fill="#0a7d6e" font-weight="700">audit who-did-what</text>

