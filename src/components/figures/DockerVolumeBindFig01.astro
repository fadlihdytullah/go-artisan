<svg viewBox="0 0 760 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Diagram perbandingan named volume dan bind mount">
  <defs>
    <marker id="dvbArrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#a3461f" />
    </marker>
  </defs>
  <rect x="20" y="20" width="720" height="340" rx="20" fill="#f6fafb" stroke="#cfd8dc" />
  <text x="48" y="56" fill="#0f1f24" font-size="21" font-weight="700">Named volume vs bind mount</text>
  <line x1="390" y1="84" x2="390" y2="344" stroke="#cfd8dc" stroke-dasharray="4 5" />

  <!-- Kiri: named volume -->
  <text x="60" y="106" fill="#a3461f" font-size="15" font-weight="700">Named volume</text>
  <rect x="60" y="122" width="280" height="72" rx="12" fill="#ffffff" stroke="#9aa7ab" />
  <text x="80" y="150" fill="#0f1f24" font-size="14.5" font-weight="700">Container (postgres)</text>
  <text x="80" y="174" fill="#516469" font-size="13">/var/lib/postgresql/data</text>
  <rect x="60" y="250" width="280" height="72" rx="12" fill="#f7e7df" stroke="#a3461f" stroke-width="2" />
  <text x="80" y="278" fill="#0f1f24" font-size="14.5" font-weight="700">Volume: pgdata</text>
  <text x="80" y="302" fill="#516469" font-size="13">dikelola Docker &middot; tetap bertahan</text>
  <path d="M 200 196 L 200 248" fill="none" stroke="#a3461f" stroke-width="2.5" marker-start="url(#dvbArrow)" marker-end="url(#dvbArrow)" />
  <text x="60" y="346" fill="#516469" font-size="12.5">-v pgdata:/var/lib/postgresql/data</text>

  <!-- Kanan: bind mount -->
  <text x="420" y="106" fill="#a3461f" font-size="15" font-weight="700">Bind mount</text>
  <rect x="420" y="122" width="280" height="72" rx="12" fill="#ffffff" stroke="#9aa7ab" />
  <text x="440" y="150" fill="#0f1f24" font-size="14.5" font-weight="700">Container (api, dev)</text>
  <text x="440" y="174" fill="#516469" font-size="13">/app</text>
  <rect x="420" y="250" width="280" height="72" rx="12" fill="#f5f9fb" stroke="#64748b" />
  <text x="440" y="278" fill="#0f1f24" font-size="14.5" font-weight="700">Host folder ./src</text>
  <text x="440" y="302" fill="#516469" font-size="13">milik laptop &middot; edit langsung</text>
  <path d="M 560 196 L 560 248" fill="none" stroke="#a3461f" stroke-width="2.5" marker-start="url(#dvbArrow)" marker-end="url(#dvbArrow)" />
  <text x="420" y="346" fill="#516469" font-size="12.5">-v $(pwd)/src:/app</text>
</svg>
