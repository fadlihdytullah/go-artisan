---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';

export interface TocItem {
  num: string;
  id: string;
  title: string;
}
export interface PagerLink {
  id: string;
  topTitle: string;
  badge: string;
}
interface Props {
  title: string;
  badge: string;
  topTitle: string;
  topSub: string;
  toc: TocItem[];
  summaryHref?: string;
  footerTitle: string;
  footerSub: string;
  prev?: PagerLink | null;
  next?: PagerLink | null;
}
const {
  title,
  badge,
  topTitle,
  topSub,
  toc,
  summaryHref = '#summary',
  footerTitle,
  footerSub,
  prev = null,
  next = null,
} = Astro.props;
---
<BaseLayout
  title={title}
  nav={{
    variant: 'module',
    moduleTitle: topTitle,
    summaryHref,
    fontControls: true,
    toc: true,
  }}
  footer={{ title: footerTitle, sub: footerSub }}
>
  <div class="reading-progress" aria-hidden="true"><span class="reading-progress-bar" data-progress></span></div>

  <div class="page-shell">
    <div class="toc-backdrop" data-toc-backdrop hidden></div>
    <nav class="toc" id="toc-nav" aria-label="Daftar isi">
      <div class="toc-head">
        <div class="toc-label">Daftar Isi</div>
        <button type="button" class="toc-close" data-toc-close aria-label="Tutup daftar isi"><Icon name="x" size={20} /></button>
      </div>
      <span class="toc-eyebrow">Di halaman ini</span>
      {toc.map((item) => (
        <a href={`#${item.id}`} data-toc-link><span class="num">{item.num}</span><span set:html={item.title} /></a>
      ))}
    </nav>

    <main>
      <a class="mod-back" href="/"><Icon name="arrow-left" size={16} />Semua modul</a>
      <slot />

      {(prev || next) && (
        <nav class="mod-pager" aria-label="Navigasi modul">
          {prev ? (
            <a class="pager-card pager-prev" href={`/modul/${prev.id}`}>
              <span class="pager-dir"><Icon name="arrow-left" size={15} />Sebelumnya</span>
              <span class="pager-name">{prev.topTitle}</span>
            </a>
          ) : <span class="pager-card pager-empty" aria-hidden="true"></span>}
          {next ? (
            <a class="pager-card pager-next" href={`/modul/${next.id}`}>
              <span class="pager-dir">Selanjutnya<Icon name="arrow-right" size={15} /></span>
              <span class="pager-name">{next.topTitle}</span>
            </a>
          ) : <span class="pager-card pager-empty" aria-hidden="true"></span>}
        </nav>
      )}
    </main>
  </div>

  <a href="#" id="toTop" aria-label="Kembali ke atas" title="Ke atas"><Icon name="arrow-up" size={20} /></a>

  <script is:inline>
    // Bilah progres baca + tombol ke atas (digabung pada satu scroll handler).
    (function () {
      var bt = document.getElementById('toTop');
      var bar = document.querySelector('[data-progress]');
      var ticking = false;
      function update() {
        ticking = false;
        var doc = document.documentElement;
        var max = doc.scrollHeight - doc.clientHeight;
        var pct = max > 0 ? doc.scrollTop / max : 0;
        if (bar) bar.style.transform = 'scaleX(' + Math.min(1, Math.max(0, pct)).toFixed(4) + ')';
        if (bt) {
          if (doc.scrollTop > 600) bt.classList.add('show');
          else bt.classList.remove('show');
        }
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { ticking = true; requestAnimationFrame(update); }
      }, { passive: true });
      update();
    })();
  </script>

  <script is:inline>
    // Scroll-spy TOC
    (function () {
      var links = document.querySelectorAll('nav.toc a[data-toc-link]');
      var sections = document.querySelectorAll('section[id]');
      var obs = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              links.forEach(function (l) { l.classList.remove('active'); });
              var active = document.querySelector('nav.toc a[href="#' + e.target.id + '"]');
              if (active) active.classList.add('active');
            }
          });
        },
        { rootMargin: '-20% 0px -70% 0px' }
      );
      sections.forEach(function (s) { obs.observe(s); });
    })();
  </script>

  <script is:inline>
    // Drawer TOC untuk mobile (≤920px)
    (function () {
      var root = document.documentElement;
      var btn = document.querySelector('[data-toc-toggle]');
      var backdrop = document.querySelector('[data-toc-backdrop]');
      var closeBtn = document.querySelector('[data-toc-close]');
      if (!btn) return;

      function open() {
        root.classList.add('toc-open');
        btn.setAttribute('aria-expanded', 'true');
        if (backdrop) backdrop.hidden = false;
      }
      function close() {
        root.classList.remove('toc-open');
        btn.setAttribute('aria-expanded', 'false');
        if (backdrop) backdrop.hidden = true;
      }
      function toggle() {
        if (root.classList.contains('toc-open')) close(); else open();
      }

      btn.addEventListener('click', toggle);
      if (backdrop) backdrop.addEventListener('click', close);
      if (closeBtn) closeBtn.addEventListener('click', close);
      document.querySelectorAll('nav.toc a[data-toc-link]').forEach(function (a) {
        a.addEventListener('click', close);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') close();
      });
    })();
  </script>

  <script is:inline>
    // Tombol "Salin" pada code block (header disisipkan transformer Shiki di astro.config).
    (function () {
      document.querySelectorAll('button[data-cb-copy]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var pre = btn.closest('pre.astro-code');
          var code = pre && pre.querySelector('code');
          var text = code ? code.innerText : '';
          if (!navigator.clipboard) return;
          navigator.clipboard.writeText(text).then(function () {
            var prev = btn.textContent;
            btn.textContent = 'Tersalin';
            btn.classList.add('is-copied');
            setTimeout(function () {
              btn.textContent = prev;
              btn.classList.remove('is-copied');
            }, 1400);
          }).catch(function () {});
        });
      });
    })();
  </script>
</BaseLayout>
