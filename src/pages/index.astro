---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import CourseCard from '../components/CourseCard.astro';
import RoadmapCard from '../components/RoadmapCard.astro';
import StatBand from '../components/StatBand.astro';
import SectionHeader from '../components/SectionHeader.astro';
import WhyBand from '../components/WhyBand.astro';
import CTABand from '../components/CTABand.astro';

// Seluruh modul backend (koleksi `modules`) → dipakai untuk continue-link & progress.
const mods = (await getCollection('modules')).sort(
  (a, b) => a.data.order - b.data.order
);
const moduleIds = mods.map((mod) => mod.id);

// Lumina (unit topik). go-luminas tampil pertama (order 0), lalu http/openapi/redis.
const luminas = (await getCollection('luminas')).sort(
  (a, b) => a.data.order - b.data.order
);
// "Latest luminas" frame nr1kS → DRVjW: 3 lumina TERBARU (order tertinggi) + promo
// "More luminas" sebagai item terakhir. slice(-3) mengambil 3 paling baru; bila lumina
// bertambah, daftar tetap 3 kartu dan sisanya dijangkau lewat kartu browse-all.
const latestLuminas = luminas.filter((c) => c.id !== 'go-luminas').slice(-3);

// Expedition unggulan (Backend Artisan tersedia; Laravel & AI menyusul/dimmed).
const roadmaps = (await getCollection('expeditions')).sort(
  (a, b) => a.data.order - b.data.order
);
const featuredRoadmap =
  roadmaps.find((r) => r.id === 'backend-artisan') ?? roadmaps[0];

// Statistik ringkas platform (dihitung langsung dari koleksi modul & lumina).
const totalModules = mods.length;
const totalLuminas = luminas.length;
const totalExpeditions = roadmaps.length || 3;

// Stat band (frame nr1kS → Pad8h). Angka real dari koleksi; caption persis frame.
const heroStats = [
  { value: totalExpeditions, label: 'Expeditions', caption: 'curated learning paths' },
  { value: totalLuminas, label: 'Luminas', caption: 'focused & practical' },
  { value: totalModules, label: 'Lessons', caption: 'in-depth written guides' },
  { value: 1, label: 'Real project', caption: 'built end to end' },
];

// "Why us" — 6 alasan (copy persis frame nr1kS → x71Z5F, UI English).
const whyItems = [
  { title: 'One clear path', body: 'No guessing where to start. Follow an ordered path from fundamentals to production.' },
  { title: 'Progress saved automatically', body: 'Stored locally in your browser. Pick up any time, no account required.' },
  { title: 'A real case study', body: 'Build a real backend end to end: catalog, cart, checkout, inventory, payments, and order lifecycle.' },
  { title: 'All the way to production', body: 'Theory plus practice: Docker, CI/CD, and deploying to the cloud the way real teams do.' },
  { title: 'Modern, idiomatic patterns', body: 'Routing, databases, caching, testing, and observability: patterns used on the job.' },
  { title: 'Dense, readable lessons', body: 'Each lesson is a focused ~60–80 minute read. No padding, no endless video.' },
];

// Disciplines index hero (frame nr1kS → PF0nx → Disciplines Index): empat path
// inti yang dicakup platform. Semua mengarah ke /roadmaps (listing) untuk kini.
const heroDisciplines = [
  { num: '01', name: 'Frontend', tag: 'Interfaces & interaction', href: '/expeditions' },
  { num: '02', name: 'Backend', tag: 'APIs & services', href: '/expeditions' },
  { num: '03', name: 'Databases', tag: 'Data & modeling', href: '/expeditions' },
  { num: '04', name: 'DevOps & Cloud', tag: 'Ship & scale', href: '/expeditions' },
];

// CTA primer default → /roadmaps; script progress me-rewrite jadi "Continue
// learning" → lesson berikutnya saat ada progres lokal (lihat inline script di bawah).
const firstLessonHref = `/lessons/${mods[0]?.id ?? ''}`;

// Promo cell "More luminas" di akhir grid luminas (frame nr1kS → L8HB9u).
const moreCoursesHref = '/luminas';
---
<BaseLayout title="Web Artisan: Learn web development, one clear path" nav={{ variant: 'home' }}>
  <main class="home-v2" data-home-progress data-module-ids={JSON.stringify(moduleIds)}>
    {/* ── Hero (bordered 1180 panel + grid backdrop) — frame PF0nx → A4mvA ──── */}
    <section class="shell-bleed hero-v2" aria-label="Web Artisan">
      <div class="hero-v2-inner">
        {/* Left: copy */}
        <div class="hero-v2-copy">
          <p class="hero-v2-kicker">
            <span class="hero-v2-dot" aria-hidden="true"></span>
            WEB ARTISAN — LEARN TO BUILD FOR THE WEB
          </p>
          <h1 class="hero-v2-title">
            Master the <span class="hero-v2-accent">craft<svg class="hero-v2-underline" viewBox="0 0 200 16" fill="none" aria-hidden="true"><path d="M4 11C54 4 140 3 196 8" stroke="currentColor" stroke-width="5" stroke-linecap="round" /></svg></span><br />
            of modern<br />
            web development.
          </h1>
          <p class="hero-v2-lead">
            Opinionated roadmaps and focused, project-based courses across the whole
            stack — frontend, backend, databases, and deployment. For people who want
            to ship real things, not collect browser tabs.
          </p>
          <div class="hero-v2-ctas">
            <a class="hero-v2-primary" href="/expeditions" data-continue-link>
              <span data-continue-label>Explore expeditions</span>
              <Icon name="arrow-right" size={18} />
            </a>
            <a class="hero-v2-secondary" href={moreCoursesHref}>Browse luminas</a>
          </div>
        </div>

        {/* Right: disciplines index — floating paper card (plain div: a nested
           complementary/region landmark inside the hero section is invalid) */}
        <div class="hero-v2-index">
          <div class="hero-v2-index-label">
            <h2 class="hero-v2-index-heading">What you'll master</h2>
            <span class="hero-v2-index-count" aria-hidden="true">04 PATHS</span>
          </div>
          <ul class="hero-v2-rows" role="list">
            {heroDisciplines.map((d) => (
              <li class="hero-v2-row">
                <a class="hero-v2-row-link" href={d.href} aria-label={`${d.name}: ${d.tag}`}>
                  <span class="hero-v2-row-num" aria-hidden="true">{d.num}</span>
                  <span class="hero-v2-row-info">
                    <span class="hero-v2-row-name">{d.name}</span>
                    <span class="hero-v2-row-tag">{d.tag}</span>
                  </span>
                  <Icon name="arrow-up-right" size={16} />
                </a>
              </li>
            ))}
          </ul>
          <a class="hero-v2-index-foot" href="/expeditions">
            View all expeditions <Icon name="arrow-right" size={15} />
          </a>
        </div>
      </div>
    </section>

    {/* ── Stats band (bracketed by full-width rules) — frame Pad8h ─────────── */}
    <StatBand stats={heroStats} />

    {/* ── Bordered 1180 column: Roadmaps + Courses sections ───────────────── */}
    <div class="shell-bleed">
      <div class="shell-col">
        {/* Explore our expeditions — frame f6AnB / ThDDR */}
        <SectionHeader eyebrow="EXPEDITIONS" title="Explore our expeditions" />
        <section class="home-v2-band" aria-label="Expeditions">
          <div class="rmc-home-grid">
            <RoadmapCard
              variant="home"
              cover={featuredRoadmap?.data.cover ?? '/backend-artisan.webp'}
              href={`/expeditions/${featuredRoadmap?.id ?? 'backend-artisan'}`}
              summary="Kuasai Go dari fondasi sampai deploy: HTTP, database, kontrak API, caching, AWS."
              meta="4 courses · 117 lessons"
              status="available"
            />
            <RoadmapCard
              variant="home"
              cover="/laravel-artisan.webp"
              href="/expeditions/laravel-artisan"
              summary="Aplikasi web modern dengan Laravel: routing, Eloquent, Blade, sampai REST API."
              meta="Coming soon"
              status="soon"
            />
            <RoadmapCard
              variant="home"
              cover="/ai-for-developers.webp"
              href="/expeditions/ai-for-developers"
              summary="Bangun produk AI: LLM, RAG, embeddings, dan agent lewat proyek nyata."
              meta="Coming soon"
              status="soon"
            />
          </div>
        </section>

        {/* Latest luminas — frame s2XtPk / DRVjW */}
        <SectionHeader
          eyebrow="LUMINAS"
          title="Latest luminas"
          lede="Focused, self-contained luminas on the core building blocks of the web."
        />
        <section class="home-v2-band" id="luminas" aria-label="Latest luminas">
          <a class="home-v2-viewall" href="/luminas">View all luminas</a>
          <div class="cc-home-grid">
            {latestLuminas.map((course) => <CourseCard course={course} variant="row" />)}
            <a class="cc-seeall" href={moreCoursesHref}>
              <span class="cc-seeall-title">More luminas</span>
              <span class="cc-seeall-link">Browse the full catalog →</span>
            </a>
          </div>
        </section>
      </div>
    </div>

    {/* ── Why us — frame x71Z5F (self-contained full-width band) ──────────── */}
    <WhyBand title="Built to take you from zero to shipping" items={whyItems} />

    {/* ── Final CTA — frame G1yUk (self-contained full-width band) ────────── */}
    <CTABand
      title="Start your first lesson today"
      sub="Free, no account needed. Your progress saves right in your browser."
      ctaLabel="Get started"
      ctaHref={moreCoursesHref}
    />
  </main>

  <script is:inline>
    // Homepage membaca progres lokal untuk CTA "Continue learning".
    (function () {
      var api = window.moduleProgress;
      var root = document.querySelector('[data-home-progress]');
      var moduleIds = [];
      var continueLink = document.querySelector('[data-continue-link]');
      var continueLabel = document.querySelector('[data-continue-label]');
      try {
        moduleIds = root ? JSON.parse(root.getAttribute('data-module-ids') || '[]') : [];
      } catch (e) {
        moduleIds = [];
      }
      if (!api || !continueLink || !continueLabel || !moduleIds.length) return;

      function sync() {
        var completedCount = api.getCompletedCount(moduleIds);
        var nextId = api.getNextModuleId(moduleIds);
        var allDone = completedCount === moduleIds.length;

        // Tanpa progres lokal: biarkan default desain ("Explore roadmaps" → /roadmaps).
        // Begitu ada progres: jadikan tombol penerus belajar ke lesson berikutnya.
        if (completedCount > 0) {
          continueLink.setAttribute('href', '/lessons/' + nextId);
          continueLabel.textContent = allDone ? 'Review learning' : 'Continue learning';
        } else {
          continueLink.setAttribute('href', '/expeditions');
          continueLabel.textContent = 'Explore expeditions';
        }
      }

      sync();

      window.addEventListener('module-progress:change', sync);
    })();
  </script>

  <style>
    /* ════════════════════════════════════════════════════════════════════════
       Home v2 (frame nr1kS). Flat, rounded, no shadow. Token-driven → reaktif
       tema light + reader. Hero full-width tanpa garis sisi; sisanya pakai
       komponen ber-band + kolom berbingkai .shell-col.
       ════════════════════════════════════════════════════════════════════════ */
    /* padding-bottom:0 override global `main{padding:0 0 112px}` → CTA menyambung
       LANGSUNG ke footer (kolom & garis sisi menerus tanpa celah cream di antara). */
    .home-v2 { display: block; padding-bottom: 0; }

    /* ── Hero ─────────────────────────────────────────────────────────────── */
    /* border-bottom:0 membuang garis bawah warisan default global `section`;
       tanpa ini garisnya bertumpuk dgn border-top StatBand → tampak ganda. */
    .hero-v2 { background: var(--bg); border-bottom: 0; padding: clamp(18px, 2.6vw, 34px) 0; }
    /* 1180 hero band — borderless; the grid pattern + floating card carry it. */
    .hero-v2-inner {
      position: relative;
      max-width: var(--shell-max, 1180px);
      margin: 0 auto;
      background: var(--bg);
      padding: clamp(40px, 5vw, 76px) clamp(24px, 4vw, 56px);
      display: grid;
      grid-template-columns: minmax(0, 1fr) 332px;
      gap: 48px;
      align-items: center;
    }
    /* Grid backdrop — mirrors hero-grid.glsl: warm hairline grid masked by a
       right-of-centre radial glow (sits behind the disciplines index). */
    .hero-v2-inner::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(to right, var(--line-strong) 1px, transparent 1px),
        linear-gradient(to bottom, var(--line-strong) 1px, transparent 1px);
      background-size: 40px 40px;
      opacity: 0.55;
      -webkit-mask-image: radial-gradient(118% 128% at 78% 46%, #000 4%, rgba(0, 0, 0, 0.22) 44%, transparent 74%);
      mask-image: radial-gradient(118% 128% at 78% 46%, #000 4%, rgba(0, 0, 0, 0.22) 44%, transparent 74%);
      pointer-events: none;
      z-index: 0;
    }
    .hero-v2-copy,
    .hero-v2-index { position: relative; z-index: 1; }

    /* Left column ───────────────────────────────────────────────────────── */
    .hero-v2-copy {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 26px;
    }
    .hero-v2-kicker {
      margin: 0;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-mono);
      font-size: 12.5px;
      font-weight: 500;
      letter-spacing: 0.18em;
      color: var(--ink-muted);
    }
    .hero-v2-dot {
      flex: 0 0 auto;
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: var(--blue-bright);
    }
    .hero-v2-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(40px, 6vw, 80px);
      font-weight: 600;
      letter-spacing: -1px;
      line-height: 1.02;
      color: var(--ink);
    }
    .hero-v2-accent {
      position: relative;
      color: var(--blue-bright);
      font-style: italic;
      white-space: nowrap;
    }
    .hero-v2-underline {
      position: absolute;
      left: 0;
      bottom: -0.16em;
      width: 100%;
      height: 0.3em;
      color: var(--blue-bright);
      overflow: visible;
    }
    .hero-v2-lead {
      margin: 0;
      max-width: 452px;
      font-family: var(--font-body);
      font-size: 17px;
      font-weight: 400;
      line-height: 1.55;
      color: var(--ink-muted);
    }
    .hero-v2-ctas {
      margin: 0;
      padding-top: 6px;
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }
    .hero-v2-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 15px 26px;
      border-radius: 12px;
      background: var(--blue-bright);   /* accent #BD5D3E */
      color: #fcfbf7;
      font-family: var(--font-body);
      font-size: 15.5px;
      font-weight: 600;
      line-height: 1;
      text-decoration: none;
      transition: background-color 0.18s ease, transform 0.2s var(--ease-spring, ease);
    }
    .hero-v2-primary :global(svg) { stroke: #fcfbf7; }
    .hero-v2-primary:hover { background: var(--blue); }
    .hero-v2-primary:focus-visible { outline: 2px solid var(--blue); outline-offset: 3px; }
    .hero-v2-secondary {
      display: inline-flex;
      align-items: center;
      padding: 15px 24px;
      border-radius: 12px;
      border: 1.4px solid var(--line-strong);
      color: var(--ink);
      font-family: var(--font-body);
      font-size: 15.5px;
      font-weight: 600;
      line-height: 1;
      text-decoration: none;
      transition: border-color 0.18s ease, color 0.18s ease;
    }
    .hero-v2-secondary:hover { border-color: var(--blue); color: var(--blue); }
    .hero-v2-secondary:focus-visible { outline: 2px solid var(--blue); outline-offset: 3px; }

    /* ── Disciplines index — floating paper card ──────────────────────────── */
    /* Paper panel that lifts off the grid pattern; a soft single-layer shadow
       gives the float without the flat brand reading as a sticker. */
    .hero-v2-index {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 0 24px;
      box-shadow: 0 14px 34px -22px rgba(34, 32, 26, 0.22);
      display: flex;
      flex-direction: column;
    }
    .hero-v2-index-label {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      padding: 22px 0 14px;
    }
    .hero-v2-index-heading,
    .hero-v2-index-count {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 11.5px;
      font-weight: 500;
      letter-spacing: 0.17em;
      text-transform: uppercase;
      color: var(--faint);
    }
    .hero-v2-rows {
      list-style: none;
      margin: 0;
      padding: 0;
      border-top: 1px solid var(--line);
    }
    .hero-v2-row {
      margin: 0;
      border-bottom: 1px solid var(--line);
    }
    .hero-v2-row-link {
      display: flex;
      align-items: center;
      gap: 18px;
      padding: 17px 2px;
      color: inherit;
      text-decoration: none;
    }
    .hero-v2-row-num {
      flex: 0 0 auto;
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--faint);
    }
    .hero-v2-row-info {
      flex: 1 1 auto;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .hero-v2-row-name {
      font-family: var(--font-body);
      font-size: 17px;
      font-weight: 600;
      color: var(--ink);
      transition: color 0.18s ease;
    }
    .hero-v2-row-tag {
      font-family: var(--font-body);
      font-size: 13.5px;
      color: var(--ink-muted);
    }
    .hero-v2-row-link :global(svg) {
      flex: 0 0 auto;
      color: var(--faint);
      transition: color 0.18s ease, transform 0.18s ease;
    }
    .hero-v2-row-link:hover .hero-v2-row-name { color: var(--blue); }
    .hero-v2-row-link:hover :global(svg) { color: var(--blue); transform: translate(2px, -2px); }
    .hero-v2-row-link:focus-visible { outline: 2px solid var(--blue); outline-offset: 2px; }
    .hero-v2-index-foot {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 16px 0 22px;
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 600;
      color: var(--blue);
      text-decoration: none;
    }
    .hero-v2-index-foot:hover { color: var(--blue-bright); }
    .hero-v2-index-foot:focus-visible { outline: 2px solid var(--blue); outline-offset: 3px; }

    /* ── Section bands inside the bordered column ─────────────────────────── */
    /* SectionHeader sudah ber-padding sendiri; band ini menambah "View all"
       di pojok kanan + grid. Padding sisi mengikuti SectionHeader (56). */
    .home-v2-band {
      position: relative;
      padding: 0 56px 56px;
    }
    .home-v2-viewall {
      position: absolute;
      top: -52px;                  /* sejajar baris title SectionHeader */
      right: 56px;
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 600;
      color: var(--blue-bright);
      text-decoration: none;
    }
    .home-v2-viewall:hover { color: var(--blue); }
    .home-v2-viewall:focus-visible { outline: 2px solid var(--blue); outline-offset: 3px; }

    /* Roadmaps: 3-kolom kartu home (frame e5k6lK) */
    .rmc-home-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }

    /* Courses: 2-kolom kartu row + promo cell (frame DRVjW) */
    .cc-home-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
    .cc-seeall {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 156px;
      padding: 24px;
      background: var(--blue-soft);          /* accent-soft #F0E3D8 */
      border: 1px solid var(--line-strong);
      border-radius: var(--radius-card);
      text-decoration: none;
      text-align: center;
      transition: border-color 0.18s ease;
    }
    .cc-seeall:hover { border-color: var(--blue); }
    .cc-seeall:focus-visible { outline: 2px solid var(--blue); outline-offset: 3px; }
    .cc-seeall-title {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 600;
      color: var(--ink);
    }
    .cc-seeall-link {
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 500;
      color: var(--blue);                    /* accent-deep #9C4A2F */
    }

    /* ── Responsive ───────────────────────────────────────────────────────── */
    /* Tablet/below: collapse hero to a single column — index stacks under the
       copy, divider hidden, glow re-centred (mirrors mobile frame OYtAe). */
    @media (max-width: 960px) {
      .hero-v2-inner {
        grid-template-columns: 1fr;
        gap: 34px;
        padding: clamp(32px, 5vw, 48px) clamp(20px, 4vw, 40px);
      }
      /* Single column: index drops below the copy as a plain list (no card). */
      .hero-v2-index {
        background: transparent;
        border: 0;
        border-radius: 0;
        padding: 0;
        box-shadow: none;
      }
      .hero-v2-index-label { padding-top: 0; }
      .hero-v2-index-foot { padding-bottom: 0; }
      .hero-v2-inner::before {
        background-size: 34px 34px;
        -webkit-mask-image: radial-gradient(130% 72% at 50% 32%, #000 4%, rgba(0, 0, 0, 0.22) 44%, transparent 74%);
        mask-image: radial-gradient(130% 72% at 50% 32%, #000 4%, rgba(0, 0, 0, 0.22) 44%, transparent 74%);
      }
      .rmc-home-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 760px) {
      .cc-home-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) {
      .home-v2-band { padding: 0 28px 40px; }
      .home-v2-viewall { right: 28px; top: -44px; }
      /* Hero goes edge-to-edge on phones: drop the cream gutter + side borders. */
      .hero-v2 { padding: 0; }
      .hero-v2-inner { border-left: 0; border-right: 0; }
      .hero-v2-title { font-size: clamp(31px, 9.5vw, 44px); }
      .hero-v2-ctas { width: 100%; flex-direction: column; align-items: stretch; }
      .hero-v2-primary,
      .hero-v2-secondary { justify-content: center; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-v2-primary { transition: background-color 0.18s ease; }
    }
  </style>
</BaseLayout>
