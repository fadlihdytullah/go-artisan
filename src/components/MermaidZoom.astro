---
// MermaidZoom — kontrol "Perbesar" + overlay fullscreen (pan & zoom) untuk
// diagram Mermaid. Dipakai di SEMUA layout yang merender ```mermaid:
// ModuleLayout (lesson/roadmap) dan halaman course (courses/[...slug]).
//
// Prasyarat: konten dibungkus elemen ber-atribut `data-module-root`, dan CSS
// `.mzoom-*` tersedia global (src/styles/globals.css). Skrip mengamati
// astro-mermaid menandai `<pre class="mermaid">[data-processed]` lalu menyuntik
// tombol di atas tiap SVG — idempotent & aman saat re-render tema.
---
  <script is:inline>
    // Diagram Mermaid: tombol "Perbesar" + overlay fullscreen dengan pan & zoom.
    // astro-mermaid me-render ```mermaid jadi <pre class="mermaid"> -> SVG di klien
    // (ditandai [data-processed]); kita amati lalu suntik kontrol di atasnya.
    (function () {
      var root = document.querySelector('[data-module-root]');
      if (!root) return;

      var svg = function (paths) {
        return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" ' +
          'stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + paths + '</svg>';
      };
      var EXPAND = svg('<path d="M16 4l4 0l0 4"/><path d="M14 10l6 -6"/><path d="M8 20l-4 0l0 -4"/><path d="M4 20l6 -6"/>');
      var PLUS = svg('<path d="M12 5l0 14"/><path d="M5 12l14 0"/>');
      var MINUS = svg('<path d="M5 12l14 0"/>');
      var FIT = svg('<path d="M5 9l0 -4l4 0"/><path d="M5 15l0 4l4 0"/><path d="M19 9l0 -4l-4 0"/><path d="M19 15l0 4l-4 0"/>');
      var XICON = svg('<path d="M18 6l-12 12"/><path d="M6 6l12 12"/>');

      // — Bangun overlay sekali, dipakai ulang untuk semua diagram —
      var overlay = document.createElement('div');
      overlay.className = 'mzoom-overlay';
      overlay.setAttribute('role', 'dialog');
      overlay.setAttribute('aria-modal', 'true');
      overlay.setAttribute('aria-label', 'Diagram diperbesar');
      overlay.hidden = true;
      overlay.innerHTML =
        '<div class="mzoom-dialog">' +
          '<div class="mzoom-bar">' +
            '<span class="mzoom-title">Diagram</span>' +
            '<div class="mzoom-tools">' +
              '<button type="button" class="mzoom-tool" data-mz="out" aria-label="Perkecil" title="Perkecil (−)">' + MINUS + '</button>' +
              '<button type="button" class="mzoom-tool" data-mz="in" aria-label="Perbesar" title="Perbesar (+)">' + PLUS + '</button>' +
              '<button type="button" class="mzoom-tool" data-mz="fit" aria-label="Pas ke layar" title="Pas ke layar (0)">' + FIT + '</button>' +
              '<button type="button" class="mzoom-tool mzoom-close" data-mz="close" aria-label="Tutup" title="Tutup (Esc)">' + XICON + '</button>' +
            '</div>' +
          '</div>' +
          '<div class="mzoom-stage"><div class="mzoom-pan"></div></div>' +
        '</div>';
      document.body.appendChild(overlay);

      var stage = overlay.querySelector('.mzoom-stage');
      var pan = overlay.querySelector('.mzoom-pan');
      var titleEl = overlay.querySelector('.mzoom-title');

      var scale = 1, tx = 0, ty = 0;
      var MIN = 0.4, MAX = 8;
      var returnFocus = null, hideTimer = null;

      function clamp(v, lo, hi) { return Math.min(hi, Math.max(lo, v)); }
      function apply() { pan.style.transform = 'translate(' + tx + 'px,' + ty + 'px) scale(' + scale + ')'; }
      function reset() { scale = 1; tx = 0; ty = 0; apply(); }
      function zoomAt(px, py, factor) {
        var ns = clamp(scale * factor, MIN, MAX);
        if (ns === scale) return;
        tx = px - (px - tx) * (ns / scale);
        ty = py - (py - ty) * (ns / scale);
        scale = ns;
        apply();
      }
      function zoomCenter(factor) {
        var r = stage.getBoundingClientRect();
        zoomAt(r.width / 2, r.height / 2, factor);
      }

      function lockScroll(on) {
        var b = document.body;
        if (on) { b.dataset.mzOv = b.style.overflow || ''; b.style.overflow = 'hidden'; }
        else { b.style.overflow = b.dataset.mzOv || ''; delete b.dataset.mzOv; }
      }

      function open(src, label) {
        if (!src) return;
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
        // JANGAN hapus id: gaya internal Mermaid di-scope ke `#mermaid-xxx`,
        // tanpa id semua fill/stroke hilang (node jadi kotak hitam).
        var clone = src.cloneNode(true);
        clone.style.maxWidth = 'none';
        pan.innerHTML = '';
        pan.appendChild(clone);
        titleEl.textContent = label || 'Diagram';
        reset();
        overlay.hidden = false;
        void overlay.offsetWidth; // paksa reflow agar transisi masuk terpicu
        overlay.classList.add('is-open');
        lockScroll(true);
        var c = overlay.querySelector('[data-mz="close"]');
        if (c) c.focus();
      }
      function close() {
        if (overlay.hidden) return;
        overlay.classList.remove('is-open');
        lockScroll(false);
        hideTimer = setTimeout(function () {
          overlay.hidden = true;
          pan.innerHTML = '';
          hideTimer = null;
        }, 220);
        if (returnFocus && document.contains(returnFocus)) returnFocus.focus();
        returnFocus = null;
      }

      // — Interaksi stage: wheel zoom-ke-kursor, drag pan, dobel-klik reset —
      stage.addEventListener('wheel', function (e) {
        e.preventDefault();
        var r = stage.getBoundingClientRect();
        zoomAt(e.clientX - r.left, e.clientY - r.top, e.deltaY < 0 ? 1.12 : 1 / 1.12);
      }, { passive: false });

      var dragging = false, lx = 0, ly = 0, pid = null;
      stage.addEventListener('pointerdown', function (e) {
        dragging = true; lx = e.clientX; ly = e.clientY; pid = e.pointerId;
        stage.classList.add('is-panning');
        try { stage.setPointerCapture(pid); } catch (_) {}
      });
      stage.addEventListener('pointermove', function (e) {
        if (!dragging) return;
        tx += e.clientX - lx; ty += e.clientY - ly;
        lx = e.clientX; ly = e.clientY;
        apply();
      });
      function endDrag() {
        if (!dragging) return;
        dragging = false;
        stage.classList.remove('is-panning');
        if (pid != null) { try { stage.releasePointerCapture(pid); } catch (_) {} pid = null; }
      }
      stage.addEventListener('pointerup', endDrag);
      stage.addEventListener('pointercancel', endDrag);
      stage.addEventListener('dblclick', function () { reset(); });

      // — Toolbar + klik backdrop —
      overlay.addEventListener('click', function (e) {
        var t = e.target.closest('[data-mz]');
        if (t) {
          var a = t.getAttribute('data-mz');
          if (a === 'in') zoomCenter(1.25);
          else if (a === 'out') zoomCenter(1 / 1.25);
          else if (a === 'fit') reset();
          else if (a === 'close') close();
          return;
        }
        if (e.target === overlay) close();
      });

      // — Keyboard: Esc tutup, +/−/0 zoom, jebak fokus (Tab) di dalam dialog —
      document.addEventListener('keydown', function (e) {
        if (overlay.hidden) return;
        if (e.key === 'Escape') { e.preventDefault(); close(); }
        else if (e.key === '+' || e.key === '=') { e.preventDefault(); zoomCenter(1.25); }
        else if (e.key === '-' || e.key === '_') { e.preventDefault(); zoomCenter(1 / 1.25); }
        else if (e.key === '0') { e.preventDefault(); reset(); }
        else if (e.key === 'Tab') {
          var f = overlay.querySelectorAll('button');
          if (!f.length) return;
          var first = f[0], last = f[f.length - 1];
          if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      });

      // — Suntik kontrol ke tiap diagram (idempotent; aman saat re-render tema) —
      function labelFor(el) {
        var cap = el.nextElementSibling;
        if (cap && cap.classList && cap.classList.contains('fig-cap')) {
          return cap.textContent.trim().slice(0, 80) || 'Diagram';
        }
        return 'Diagram';
      }
      function enhance() {
        root.querySelectorAll('.mermaid').forEach(function (el) {
          if (!el.querySelector('svg')) return;
          if (!el.querySelector('.mzoom-btn')) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'mzoom-btn';
            btn.setAttribute('aria-label', 'Perbesar diagram');
            btn.innerHTML = EXPAND + '<span>Perbesar</span>';
            btn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              returnFocus = btn;
              open(el.querySelector('svg'), labelFor(el));
            });
            el.appendChild(btn);
          }
          if (!el.dataset.mzBound) {
            el.dataset.mzBound = '1';
            var sx = 0, sy = 0;
            el.addEventListener('pointerdown', function (e) { sx = e.clientX; sy = e.clientY; });
            el.addEventListener('click', function (e) {
              if (e.target.closest('.mzoom-btn')) return;
              if (Math.abs(e.clientX - sx) > 6 || Math.abs(e.clientY - sy) > 6) return; // seleksi/scroll, bukan klik
              returnFocus = null;
              open(el.querySelector('svg'), labelFor(el));
            });
          }
        });
      }

      var pending = false;
      function schedule() {
        if (pending) return;
        pending = true;
        requestAnimationFrame(function () { pending = false; enhance(); });
      }
      new MutationObserver(schedule).observe(root, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ['data-processed'],
      });
      enhance();
    })();
  </script>
