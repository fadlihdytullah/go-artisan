---
import ArticleTOC from './ArticleTOC.astro';
import LessonPager from './LessonPager.astro';

interface ArticleTocItem {
  num?: string;
  id: string;
  title: string;
}

interface Link {
  id: string;
  topTitle: string;
  badge: string;
}

interface Props {
  toc: ArticleTocItem[];
  prev: Link | null;
  next: Link | null;
  basePath: string;
  moduleId: string;
  tocHeading?: string;
  articleTopPadding?: boolean;
}

const {
  toc,
  prev,
  next,
  basePath,
  moduleId,
  tocHeading = 'On this page',
  articleTopPadding = false,
} = Astro.props;

const hasHeader = Astro.slots.has('header');
---

<div class="shell-bleed">
  <div class="shell-col">
    <div
      class:list={[
        'course-detail-shell',
        { 'has-header': hasHeader, 'article-top-padding': articleTopPadding },
      ]}
    >
      <div class="course-detail-layout">
        <div class="toc-sheet" data-toc-sheet>
          <div class="toc-sheet-handle"></div>
          <div class="toc-sheet-head">
            <span class="toc-sheet-label">Daftar Isi</span>
            <button class="toc-sheet-close" data-toc-close aria-label="Tutup daftar isi">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6l-12 12" /><path d="M6 6l12 12" /></svg>
            </button>
          </div>
          <div class="toc-sheet-body">
            <ArticleTOC toc={toc} heading={tocHeading} />
          </div>
        </div>

        {hasHeader && (
          <header class="course-detail-header">
            <slot name="header" />
          </header>
        )}

        <article class="course-article" data-module-root data-module-id={moduleId}>
          <slot />
        </article>
      </div>

      <div class="toc-backdrop" data-toc-backdrop hidden></div>
      <button class="toc-fab" data-toc-toggle aria-label="Daftar Isi" aria-expanded="false">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6l16 0" /><path d="M4 12l16 0" /><path d="M4 18l16 0" /></svg>
        <span>Daftar Isi</span>
      </button>

      <div class="pager-wrap">
        <LessonPager prev={prev} next={next} basePath={basePath} />
      </div>
    </div>
  </div>
</div>

<a href="#" id="toTop" aria-label="Kembali ke atas" title="Ke atas">
  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5l0 14" /><path d="M18 11l-6 -6" /><path d="M6 11l6 -6" /></svg>
</a>

<script is:inline>
  (function () {
    var bt = document.getElementById('toTop');
    function onScroll() {
      var top = document.documentElement.scrollTop;
      if (bt) bt.classList.toggle('show', top > 600);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    var links = document.querySelectorAll('nav.article-toc a[data-toc-link]');
    var sections = document.querySelectorAll('article.course-article section[id]');
    if (links.length && sections.length && 'IntersectionObserver' in window) {
      var obs = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              links.forEach(function (l) { l.classList.remove('active'); });
              var active = document.querySelector(
                'nav.article-toc a[href="#' + e.target.id + '"]'
              );
              if (active) active.classList.add('active');
            }
          });
        },
        { rootMargin: '-15% 0px -60% 0px' }
      );
      sections.forEach(function (s) { obs.observe(s); });
    }
  })();

  (function () {
    var sheet = document.querySelector('[data-toc-sheet]');
    var backdrop = document.querySelector('[data-toc-backdrop]');
    var toggles = document.querySelectorAll('[data-toc-toggle]');
    var closeBtn = document.querySelector('[data-toc-close]');
    var links = sheet ? sheet.querySelectorAll('a[data-toc-link]') : [];

    function openSheet() {
      if (!sheet || !backdrop) return;
      sheet.classList.add('open');
      backdrop.removeAttribute('hidden');
      toggles.forEach(function (b) { b.setAttribute('aria-expanded', 'true'); });
      document.body.style.overflow = 'hidden';
    }
    function closeSheet() {
      if (!sheet || !backdrop) return;
      sheet.classList.remove('open');
      backdrop.setAttribute('hidden', '');
      toggles.forEach(function (b) { b.setAttribute('aria-expanded', 'false'); });
      document.body.style.overflow = '';
    }

    toggles.forEach(function (b) {
      b.addEventListener('click', function (e) {
        e.preventDefault();
        if (sheet && sheet.classList.contains('open')) closeSheet();
        else openSheet();
      });
    });

    if (backdrop) backdrop.addEventListener('click', closeSheet);
    if (closeBtn) closeBtn.addEventListener('click', closeSheet);

    links.forEach(function (l) {
      l.addEventListener('click', closeSheet);
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && sheet && sheet.classList.contains('open')) closeSheet();
    });
  })();
</script>

<style>
  .course-detail-shell {
    position: relative;
  }
  .course-detail-shell::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 330px;
    width: 1px;
    background: var(--line);
  }

  .course-detail-layout {
    display: grid;
    grid-template-columns: 330px minmax(0, 1fr);
    grid-template-areas: "toc body";
    align-items: start;
  }
  .course-detail-shell.has-header .course-detail-layout {
    grid-template-areas:
      "toc header"
      "toc body";
  }

  .toc-sheet {
    grid-area: toc;
  }

  .course-detail-header {
    grid-area: header;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 56px 56px 0;
  }

  .course-article {
    grid-area: body;
    min-width: 0;
    padding: 0 56px 64px;
  }
  .course-detail-shell.article-top-padding .course-article {
    padding-top: 56px;
  }

  .pager-wrap {
    display: grid;
    grid-template-columns: 330px minmax(0, 1fr);
    grid-template-areas: "toc pager";
    padding-bottom: 48px;
  }
  .pager-wrap :global(.mod-pager) {
    grid-area: pager;
    max-width: none;
    margin: 0;
    padding: 0 56px;
  }

  #toTop {
    position: fixed;
    right: 24px;
    bottom: 24px;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: var(--paper);
    color: var(--ink-soft);
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease, background-color 0.15s ease;
    z-index: 40;
  }
  #toTop.show {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  #toTop:hover {
    background: var(--paper-soft);
    color: var(--ink);
  }

  /* ── Bottom-sheet TOC (mobile only) ── */
  .toc-sheet-handle {
    display: block;
    width: 36px;
    height: 4px;
    margin: 8px auto 4px;
    border-radius: 99px;
    background: var(--line-strong);
    flex: none;
  }
  .toc-sheet-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 18px 8px;
  }
  .toc-sheet-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--faint);
  }
  .toc-sheet-close {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--ink-muted);
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .toc-sheet-close:hover {
    background: var(--line);
    color: var(--ink);
  }
  .toc-sheet-body {
    padding: 0 18px 16px;
  }

  .toc-backdrop {
    position: fixed;
    inset: 0;
    z-index: 70;
    background: rgba(15, 23, 42, 0.4);
    backdrop-filter: blur(2px);
  }
  .toc-backdrop[hidden] {
    display: none;
  }

  .toc-fab {
    display: none;
    position: fixed;
    left: max(20px, env(safe-area-inset-left));
    bottom: max(20px, env(safe-area-inset-bottom));
    z-index: 50;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }
  .toc-fab:hover {
    background: var(--paper-soft);
  }

  @media (max-width: 920px) {
    .course-detail-layout {
      grid-template-columns: minmax(0, 1fr);
      grid-template-areas: "body";
      row-gap: 0;
    }
    .course-detail-shell.has-header .course-detail-layout {
      grid-template-areas:
        "header"
        "body";
    }
    .toc-sheet {
      position: fixed;
      inset: auto 0 0 0;
      z-index: 80;
      display: flex;
      flex-direction: column;
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      max-height: 55vh;
      background: var(--paper);
      border-radius: 16px 16px 0 0;
      box-shadow: 0 -4px 24px rgba(0,0,0,0.08);
      overflow-y: auto;
    }
    .toc-sheet.open {
      transform: translateY(0);
    }
    .toc-fab {
      display: inline-flex;
    }
    .course-detail-shell::before {
      display: none;
    }
    .course-detail-header {
      padding: 40px 28px 0;
    }
    .course-article {
      padding: 0 28px 56px;
    }
    .course-detail-shell.article-top-padding .course-article {
      padding-top: 40px;
    }
    .pager-wrap {
      grid-template-columns: minmax(0, 1fr);
      grid-template-areas: "pager";
    }
    .pager-wrap :global(.mod-pager) {
      padding: 0 28px;
    }
  }

  @media (max-width: 680px) {
    .course-detail-header {
      padding: 36px 20px 0;
    }
    .course-article {
      padding: 0 20px 44px;
    }
    .course-detail-shell.article-top-padding .course-article {
      padding-top: 36px;
    }
    .pager-wrap :global(.mod-pager) {
      padding: 0 20px;
    }
  }
</style>
