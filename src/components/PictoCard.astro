---
import Icon from './Icon.astro';

interface Props {
  slug: string;
  topic: string;
  title: string;
  dek: string;
  icon: string;
  readTime: string;
  date: string;
}

const { slug, topic, title, dek, icon, readTime, date } = Astro.props;
const href = `/pictos/${slug}`;

const VALID_ICONS = [
  'layers', 'git', 'lock', 'database', 'package', 'bug', 'shield',
  'stack', 'bolt', 'server', 'code', 'terminal', 'rocket',
] as const;
type ValidIcon = typeof VALID_ICONS[number];
const safeIcon = (VALID_ICONS.includes(icon as ValidIcon) ? icon : 'stack') as ValidIcon;
---
<a class="pc" href={href}>
  <div class="pc-top">
    <span class="pc-glyph" aria-hidden="true">
      <Icon name={safeIcon} size={20} />
    </span>
    <span class="pc-topic">{topic}</span>
  </div>
  <p class="pc-title">{title}</p>
  <p class="pc-dek">{dek}</p>
  <span class="pc-spacer" aria-hidden="true"></span>
  <hr class="pc-divider" />
  <div class="pc-meta">
    <span class="pc-meta-left">
      <span>{readTime}</span>
      <span class="pc-dot" aria-hidden="true">·</span>
      <span>{date}</span>
    </span>
    <span class="pc-read" aria-label={`Read: ${title}`}>
      Read
      <Icon name="arrow-right" size={13} />
    </span>
  </div>
</a>

<style>
  .pc {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: var(--paper);
    text-decoration: none;
    color: inherit;
    min-height: 284px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .pc:hover {
    border-color: var(--line-strong);
  }

  .pc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .pc-glyph {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 11px;
    background: var(--blue-soft);
    color: var(--blue-bright);
    flex: 0 0 auto;
  }

  .pc-topic {
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--ink-muted);
  }

  .pc-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 600;
    letter-spacing: -0.3px;
    line-height: 1.25;
    color: var(--ink);
  }

  .pc-dek {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.5;
    color: var(--ink-muted);
  }

  .pc-spacer {
    flex: 1 1 auto;
  }

  .pc-divider {
    margin: 0;
    border: none;
    border-top: 1px solid var(--line);
    width: 100%;
  }

  .pc-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .pc-meta-left {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 500;
    color: var(--faint);
  }

  .pc-dot {
    color: var(--line-strong);
  }

  .pc-read {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--blue);
  }
</style>
