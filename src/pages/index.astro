---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import CourseCard from '../components/CourseCard.astro';

// Seluruh modul backend (koleksi `modules`) → dipakai untuk continue-link & progress.
const mods = (await getCollection('modules')).sort(
  (a, b) => a.data.order - b.data.order
);
const moduleIds = mods.map((mod) => mod.id);

// Course (unit topik). go-luminas tampil pertama (order 0), lalu http/openapi/redis.
const courses = (await getCollection('courses')).sort(
  (a, b) => a.data.order - b.data.order
);

// Roadmap unggulan untuk kartu banner (saat ini: Backend Artisan).
const roadmaps = (await getCollection('roadmaps')).sort(
  (a, b) => a.data.order - b.data.order
);
const featuredRoadmap =
  roadmaps.find((r) => r.id === 'backend-artisan') ?? roadmaps[0];

// Statistik ringkas platform (dihitung langsung dari koleksi modul & course).
const totalModules = mods.length;
const totalCourses = courses.length;

// Cuplikan Go untuk visual hero - idiomatik & relevan dengan jalur backend (chi router).
// Di-render via set:html agar kurung kurawal tidak bentrok dengan ekspresi Astro.
const heroCode = [
  '<span class="k">package</span> main',
  '',
  '<span class="k">import</span> (',
  '\t<span class="s">"net/http"</span>',
  '',
  '\t<span class="s">"github.com/go-chi/chi/v5"</span>',
  ')',
  '',
  '<span class="k">func</span> <span class="f">main</span>() {',
  '\tr := chi.<span class="f">NewRouter</span>()',
  '',
  '\t<span class="c">// daftar produk skincare</span>',
  '\tr.<span class="f">Get</span>(<span class="s">"/produk"</span>, listProduk)',
  '',
  '\thttp.<span class="f">ListenAndServe</span>(<span class="s">":8080"</span>, r)',
  '}',
].join('\n');
---
<BaseLayout title="Web Artisan - Belajar Web Development" nav={{ variant: 'home' }}>
  <main class="home" data-home-progress data-module-ids={JSON.stringify(moduleIds)}>
    <section class="home-hero">
      <div class="home-hero-grid">
        <div class="home-hero-copy">
          <p class="home-eyebrow"><span class="dot" aria-hidden="true"></span>Platform belajar web development</p>

          <h1 class="home-title">Belajar web development, satu jalur jelas dari nol</h1>

          <p class="home-lede">
            <b>Web Artisan</b> adalah platform belajar web development yang terus tumbuh.
            Jalur yang tersedia sekarang adalah <b>backend</b>: kuasai Go dari fondasi bahasa,
            HTTP, kontrak API, sampai caching dan deploy produksi. Jalur frontend menyusul.
          </p>

          <dl class="home-stats">
            <div><dt>{totalCourses}</dt><dd>course</dd></div>
            <div><dt>{totalModules}</dt><dd>modul</dd></div>
            <div><dt>1</dt><dd>roadmap</dd></div>
            <div><dt>1</dt><dd>proyek nyata</dd></div>
          </dl>

          <div class="home-actions">
            <a class="home-cta" href={`/lessons/${mods[0]?.id ?? ''}`} data-continue-link>
              <span data-continue-label>Mulai belajar</span>
              <Icon name="arrow-right" size={17} />
            </a>
            <a class="home-secondary-link" href="/courses/go-luminas">Lihat kurikulum Go Luminas</a>
          </div>

          <section
            class="learning-progress-panel learning-progress-panel-home"
            data-learning-progress
            data-module-ids={JSON.stringify(moduleIds)}
            aria-label="Progress belajar"
          >
            <div class="learning-progress-head">
              <div>
                <p class="learning-progress-kicker">Progress belajar</p>
                <p class="learning-progress-context">Tersimpan lokal di browser ini</p>
              </div>
              <p class="learning-progress-stats">
                <span data-learning-progress-value>0%</span>
                <span data-learning-progress-count>0/{moduleIds.length} modul selesai</span>
              </p>
            </div>
            <div
              class="learning-progress-meter"
              data-learning-progress-meter
              role="progressbar"
              aria-label="Progress kursus"
              aria-valuemin="0"
              aria-valuemax={moduleIds.length}
              aria-valuenow="0"
            >
              <span class="learning-progress-fill" data-learning-progress-fill></span>
            </div>
            <p class="learning-progress-copy" data-learning-progress-copy>
              Belum ada progres tersimpan. Mulai dari modul pertama atau masuk ke topik yang paling relevan untuk kerja backend-mu sekarang.
            </p>
          </section>
        </div>

        <div class="home-code" aria-hidden="true">
          <div class="home-code-bar">
            <span class="home-code-dots"><i></i><i></i><i></i></span>
            <span class="home-code-file">main.go</span>
            <span class="home-code-tag">Go + chi</span>
          </div>
          <pre class="home-code-body"><code set:html={heroCode}></code></pre>
        </div>
      </div>
    </section>

    {featuredRoadmap && (
      <section class="home-modules" aria-label="Roadmap unggulan">
        <div class="home-modules-head">
          <h2>Roadmap unggulan</h2>
          <a class="count home-roadmaps-all" href="/roadmaps">Semua roadmap</a>
        </div>
        <a class="roadmap-banner" href={`/roadmaps/${featuredRoadmap.id}`}>
          <span class="roadmap-banner-media">
            <img
              src={featuredRoadmap.data.cover}
              alt={`Banner roadmap ${featuredRoadmap.data.title}`}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </span>
          <span class="roadmap-banner-body">
            <span class="roadmap-banner-badge">{featuredRoadmap.data.badge}</span>
            <span class="roadmap-banner-title">{featuredRoadmap.data.hero}</span>
            <span class="roadmap-banner-sum">{featuredRoadmap.data.summary}</span>
          </span>
        </a>
      </section>
    )}

    {courses.length > 0 && (
      <section class="home-modules home-courses" id="courses">
        <div class="home-modules-head">
          <h2>Courses</h2>
          <a class="count home-roadmaps-all" href="/courses">Semua course</a>
        </div>
        <p class="home-courses-lede">
          Tiap course adalah satu unit topik. Mulai dari Go Luminas sebagai fondasi penuh,
          lalu perdalam HTTP, OpenAPI, dan Redis sesuai kebutuhan backend-mu.
        </p>
        <div class="course-grid">
          {courses.map((course) => <CourseCard course={course} />)}
        </div>
      </section>
    )}
  </main>

  <script is:inline>
    // Homepage membaca progres lokal untuk CTA "Continue learning".
    (function () {
      var api = window.moduleProgress;
      var root = document.querySelector('[data-home-progress]');
      var moduleIds = [];
      var continueLink = document.querySelector('[data-continue-link]');
      var continueLabel = document.querySelector('[data-continue-label]');
      try {
        moduleIds = root ? JSON.parse(root.getAttribute('data-module-ids') || '[]') : [];
      } catch (e) {
        moduleIds = [];
      }
      if (!api || !continueLink || !continueLabel || !moduleIds.length) return;

      function sync() {
        var completedCount = api.getCompletedCount(moduleIds);
        var nextId = api.getNextModuleId(moduleIds);
        var allDone = completedCount === moduleIds.length;

        continueLink.setAttribute('href', '/lessons/' + nextId);
        continueLabel.textContent = allDone ? 'Review belajar' : completedCount > 0 ? 'Continue learning' : 'Mulai belajar';
      }

      sync();

      window.addEventListener('module-progress:change', sync);
    })();
  </script>
</BaseLayout>
