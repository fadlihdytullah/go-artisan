---
import BaseLayout from './BaseLayout.astro';
import Icon from '../components/Icon.astro';

export interface TocItem {
  num: string;
  id: string;
  title: string;
}
export interface PagerLink {
  id: string;
  topTitle: string;
  badge: string;
}
interface Props {
  moduleId: string;
  title: string;
  badge: string;
  topTitle: string;
  topSub: string;
  toc: TocItem[];
  summaryHref?: string;
  footerTitle: string;
  footerSub: string;
  prev?: PagerLink | null;
  next?: PagerLink | null;
}
const {
  moduleId,
  title,
  badge,
  topTitle,
  topSub,
  toc,
  summaryHref = '#summary',
  footerTitle,
  footerSub,
  prev = null,
  next = null,
} = Astro.props;
---
<BaseLayout
  title={title}
  nav={{
    variant: 'module',
    moduleTitle: topTitle,
    summaryHref,
    fontControls: true,
    toc: true,
  }}
  footer={{ title: footerTitle, sub: footerSub }}
>
  <div class="reading-progress" aria-hidden="true"><span class="reading-progress-bar" data-progress></span></div>

  <div class="page-shell">
    <div class="toc-backdrop" data-toc-backdrop hidden></div>
    <nav class="toc" id="toc-nav" aria-label="Daftar isi">
      <div class="toc-head">
        <div class="toc-label">Daftar Isi</div>
        <button type="button" class="toc-close" data-toc-close aria-label="Tutup daftar isi"><Icon name="x" size={20} /></button>
      </div>
      <span class="toc-eyebrow">Di halaman ini</span>
      {toc.map((item) => (
        <a href={`#${item.id}`} data-toc-link><span class="num">{item.num}</span><span set:html={item.title} /></a>
      ))}
    </nav>

    <main data-module-root data-module-id={moduleId}>
      <a class="mod-back" href="/"><Icon name="arrow-left" size={16} />Semua modul</a>
      <div class="module-actions module-actions-top">
        <button
          type="button"
          class="module-complete-btn"
          data-complete-toggle
          data-module-id={moduleId}
          aria-pressed="false"
        >
          <span class="module-complete-btn-text">Mark as completed</span>
        </button>
        <p class="module-complete-note" data-complete-note>Progress disimpan lokal di browser ini.</p>
      </div>
      <slot />

      <div class="module-actions module-actions-bottom">
        <button
          type="button"
          class="module-complete-btn"
          data-complete-toggle
          data-module-id={moduleId}
          aria-pressed="false"
        >
          <span class="module-complete-btn-text">Mark as completed</span>
        </button>
        <p class="module-complete-note" data-complete-note>Progress disimpan lokal di browser ini.</p>
      </div>

      {(prev || next) && (
        <nav class="mod-pager" aria-label="Navigasi modul">
          {prev ? (
            <a class="pager-card pager-prev" href={`/modul/${prev.id}`}>
              <span class="pager-dir"><Icon name="arrow-left" size={15} />Sebelumnya</span>
              <span class="pager-name">{prev.topTitle}</span>
            </a>
          ) : <span class="pager-card pager-empty" aria-hidden="true"></span>}
          {next ? (
            <a class="pager-card pager-next" href={`/modul/${next.id}`}>
              <span class="pager-dir">Selanjutnya<Icon name="arrow-right" size={15} /></span>
              <span class="pager-name">{next.topTitle}</span>
            </a>
          ) : <span class="pager-card pager-empty" aria-hidden="true"></span>}
        </nav>
      )}
    </main>
  </div>

  <a href="#" id="toTop" aria-label="Kembali ke atas" title="Ke atas"><Icon name="arrow-up" size={20} /></a>

  <script is:inline>
    // Bilah progres baca + tombol ke atas (digabung pada satu scroll handler).
    (function () {
      var bt = document.getElementById('toTop');
      var bar = document.querySelector('[data-progress]');
      var ticking = false;
      function update() {
        ticking = false;
        var doc = document.documentElement;
        var max = doc.scrollHeight - doc.clientHeight;
        var pct = max > 0 ? doc.scrollTop / max : 0;
        if (bar) bar.style.transform = 'scaleX(' + Math.min(1, Math.max(0, pct)).toFixed(4) + ')';
        if (bt) {
          if (doc.scrollTop > 600) bt.classList.add('show');
          else bt.classList.remove('show');
        }
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { ticking = true; requestAnimationFrame(update); }
      }, { passive: true });
      update();
    })();
  </script>

  <script is:inline>
    // Scroll-spy TOC
    (function () {
      var links = document.querySelectorAll('nav.toc a[data-toc-link]');
      var sections = document.querySelectorAll('section[id]');
      var obs = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              links.forEach(function (l) { l.classList.remove('active'); });
              var active = document.querySelector('nav.toc a[href="#' + e.target.id + '"]');
              if (active) active.classList.add('active');
            }
          });
        },
        { rootMargin: '-20% 0px -70% 0px' }
      );
      sections.forEach(function (s) { obs.observe(s); });
    })();
  </script>

  <script is:inline>
    // Drawer TOC untuk mobile (≤920px)
    (function () {
      var root = document.documentElement;
      var btn = document.querySelector('[data-toc-toggle]');
      var backdrop = document.querySelector('[data-toc-backdrop]');
      var closeBtn = document.querySelector('[data-toc-close]');
      if (!btn) return;

      function open() {
        root.classList.add('toc-open');
        btn.setAttribute('aria-expanded', 'true');
        if (backdrop) backdrop.hidden = false;
      }
      function close() {
        root.classList.remove('toc-open');
        btn.setAttribute('aria-expanded', 'false');
        if (backdrop) backdrop.hidden = true;
      }
      function toggle() {
        if (root.classList.contains('toc-open')) close(); else open();
      }

      btn.addEventListener('click', toggle);
      if (backdrop) backdrop.addEventListener('click', close);
      if (closeBtn) closeBtn.addEventListener('click', close);
      document.querySelectorAll('nav.toc a[data-toc-link]').forEach(function (a) {
        a.addEventListener('click', close);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') close();
      });
    })();
  </script>

  <script is:inline>
    // Tombol "Salin" pada code block (header disisipkan transformer Shiki di astro.config).
    (function () {
      document.querySelectorAll('button[data-cb-copy]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var pre = btn.closest('pre.astro-code');
          var code = pre && pre.querySelector('code');
          var text = code ? code.innerText : '';
          if (!navigator.clipboard) return;
          navigator.clipboard.writeText(text).then(function () {
            var prev = btn.textContent;
            btn.textContent = 'Tersalin';
            btn.classList.add('is-copied');
            setTimeout(function () {
              btn.textContent = prev;
              btn.classList.remove('is-copied');
            }, 1400);
          }).catch(function () {});
        });
      });
    })();
  </script>

  <script is:inline>
    // Toggle progres selesai untuk modul saat ini.
    (function () {
      var api = window.moduleProgress;
      var root = document.querySelector('[data-module-root]');
      var moduleId = root ? root.getAttribute('data-module-id') : '';
      var buttons = Array.prototype.slice.call(document.querySelectorAll('[data-complete-toggle]'));
      var notes = Array.prototype.slice.call(document.querySelectorAll('[data-complete-note]'));
      if (!api || !moduleId || !buttons.length) return;

      function sync() {
        var done = api.isCompleted(moduleId);
        buttons.forEach(function (btn) {
          var label = btn.querySelector('.module-complete-btn-text');
          btn.setAttribute('aria-pressed', done ? 'true' : 'false');
          btn.classList.toggle('is-complete', done);
          if (label) label.textContent = done ? 'Mark as incomplete' : 'Mark as completed';
        });
        notes.forEach(function (note) {
          note.textContent = done
            ? 'Modul ini ditandai selesai di browser ini. Kamu bisa klik lagi untuk membatalkan.'
            : 'Progress disimpan lokal di browser ini.';
        });
      }

      api.setLastVisited(moduleId);
      sync();

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          api.setCompleted(moduleId, !api.isCompleted(moduleId));
          api.setLastVisited(moduleId);
          sync();
        });
      });

      window.addEventListener('module-progress:change', sync);
    })();
  </script>

  <script is:inline>
    // Diagram Mermaid: tombol "Perbesar" + overlay fullscreen dengan pan & zoom.
    // astro-mermaid me-render ```mermaid jadi <pre class="mermaid"> -> SVG di klien
    // (ditandai [data-processed]); kita amati lalu suntik kontrol di atasnya.
    (function () {
      var root = document.querySelector('[data-module-root]');
      if (!root) return;

      var svg = function (paths) {
        return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" ' +
          'stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + paths + '</svg>';
      };
      var EXPAND = svg('<path d="M16 4l4 0l0 4"/><path d="M14 10l6 -6"/><path d="M8 20l-4 0l0 -4"/><path d="M4 20l6 -6"/>');
      var PLUS = svg('<path d="M12 5l0 14"/><path d="M5 12l14 0"/>');
      var MINUS = svg('<path d="M5 12l14 0"/>');
      var FIT = svg('<path d="M5 9l0 -4l4 0"/><path d="M5 15l0 4l4 0"/><path d="M19 9l0 -4l-4 0"/><path d="M19 15l0 4l-4 0"/>');
      var XICON = svg('<path d="M18 6l-12 12"/><path d="M6 6l12 12"/>');

      // — Bangun overlay sekali, dipakai ulang untuk semua diagram —
      var overlay = document.createElement('div');
      overlay.className = 'mzoom-overlay';
      overlay.setAttribute('role', 'dialog');
      overlay.setAttribute('aria-modal', 'true');
      overlay.setAttribute('aria-label', 'Diagram diperbesar');
      overlay.hidden = true;
      overlay.innerHTML =
        '<div class="mzoom-dialog">' +
          '<div class="mzoom-bar">' +
            '<span class="mzoom-title">Diagram</span>' +
            '<div class="mzoom-tools">' +
              '<button type="button" class="mzoom-tool" data-mz="out" aria-label="Perkecil" title="Perkecil (−)">' + MINUS + '</button>' +
              '<button type="button" class="mzoom-tool" data-mz="in" aria-label="Perbesar" title="Perbesar (+)">' + PLUS + '</button>' +
              '<button type="button" class="mzoom-tool" data-mz="fit" aria-label="Pas ke layar" title="Pas ke layar (0)">' + FIT + '</button>' +
              '<button type="button" class="mzoom-tool mzoom-close" data-mz="close" aria-label="Tutup" title="Tutup (Esc)">' + XICON + '</button>' +
            '</div>' +
          '</div>' +
          '<div class="mzoom-stage"><div class="mzoom-pan"></div></div>' +
        '</div>';
      document.body.appendChild(overlay);

      var stage = overlay.querySelector('.mzoom-stage');
      var pan = overlay.querySelector('.mzoom-pan');
      var titleEl = overlay.querySelector('.mzoom-title');

      var scale = 1, tx = 0, ty = 0;
      var MIN = 0.4, MAX = 8;
      var returnFocus = null, hideTimer = null;

      function clamp(v, lo, hi) { return Math.min(hi, Math.max(lo, v)); }
      function apply() { pan.style.transform = 'translate(' + tx + 'px,' + ty + 'px) scale(' + scale + ')'; }
      function reset() { scale = 1; tx = 0; ty = 0; apply(); }
      function zoomAt(px, py, factor) {
        var ns = clamp(scale * factor, MIN, MAX);
        if (ns === scale) return;
        tx = px - (px - tx) * (ns / scale);
        ty = py - (py - ty) * (ns / scale);
        scale = ns;
        apply();
      }
      function zoomCenter(factor) {
        var r = stage.getBoundingClientRect();
        zoomAt(r.width / 2, r.height / 2, factor);
      }

      function lockScroll(on) {
        var b = document.body;
        if (on) { b.dataset.mzOv = b.style.overflow || ''; b.style.overflow = 'hidden'; }
        else { b.style.overflow = b.dataset.mzOv || ''; delete b.dataset.mzOv; }
      }

      function open(src, label) {
        if (!src) return;
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
        // JANGAN hapus id: gaya internal Mermaid di-scope ke `#mermaid-xxx`,
        // tanpa id semua fill/stroke hilang (node jadi kotak hitam).
        var clone = src.cloneNode(true);
        clone.style.maxWidth = 'none';
        pan.innerHTML = '';
        pan.appendChild(clone);
        titleEl.textContent = label || 'Diagram';
        reset();
        overlay.hidden = false;
        void overlay.offsetWidth; // paksa reflow agar transisi masuk terpicu
        overlay.classList.add('is-open');
        lockScroll(true);
        var c = overlay.querySelector('[data-mz="close"]');
        if (c) c.focus();
      }
      function close() {
        if (overlay.hidden) return;
        overlay.classList.remove('is-open');
        lockScroll(false);
        hideTimer = setTimeout(function () {
          overlay.hidden = true;
          pan.innerHTML = '';
          hideTimer = null;
        }, 220);
        if (returnFocus && document.contains(returnFocus)) returnFocus.focus();
        returnFocus = null;
      }

      // — Interaksi stage: wheel zoom-ke-kursor, drag pan, dobel-klik reset —
      stage.addEventListener('wheel', function (e) {
        e.preventDefault();
        var r = stage.getBoundingClientRect();
        zoomAt(e.clientX - r.left, e.clientY - r.top, e.deltaY < 0 ? 1.12 : 1 / 1.12);
      }, { passive: false });

      var dragging = false, lx = 0, ly = 0, pid = null;
      stage.addEventListener('pointerdown', function (e) {
        dragging = true; lx = e.clientX; ly = e.clientY; pid = e.pointerId;
        stage.classList.add('is-panning');
        try { stage.setPointerCapture(pid); } catch (_) {}
      });
      stage.addEventListener('pointermove', function (e) {
        if (!dragging) return;
        tx += e.clientX - lx; ty += e.clientY - ly;
        lx = e.clientX; ly = e.clientY;
        apply();
      });
      function endDrag() {
        if (!dragging) return;
        dragging = false;
        stage.classList.remove('is-panning');
        if (pid != null) { try { stage.releasePointerCapture(pid); } catch (_) {} pid = null; }
      }
      stage.addEventListener('pointerup', endDrag);
      stage.addEventListener('pointercancel', endDrag);
      stage.addEventListener('dblclick', function () { reset(); });

      // — Toolbar + klik backdrop —
      overlay.addEventListener('click', function (e) {
        var t = e.target.closest('[data-mz]');
        if (t) {
          var a = t.getAttribute('data-mz');
          if (a === 'in') zoomCenter(1.25);
          else if (a === 'out') zoomCenter(1 / 1.25);
          else if (a === 'fit') reset();
          else if (a === 'close') close();
          return;
        }
        if (e.target === overlay) close();
      });

      // — Keyboard: Esc tutup, +/−/0 zoom, jebak fokus (Tab) di dalam dialog —
      document.addEventListener('keydown', function (e) {
        if (overlay.hidden) return;
        if (e.key === 'Escape') { e.preventDefault(); close(); }
        else if (e.key === '+' || e.key === '=') { e.preventDefault(); zoomCenter(1.25); }
        else if (e.key === '-' || e.key === '_') { e.preventDefault(); zoomCenter(1 / 1.25); }
        else if (e.key === '0') { e.preventDefault(); reset(); }
        else if (e.key === 'Tab') {
          var f = overlay.querySelectorAll('button');
          if (!f.length) return;
          var first = f[0], last = f[f.length - 1];
          if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      });

      // — Suntik kontrol ke tiap diagram (idempotent; aman saat re-render tema) —
      function labelFor(el) {
        var cap = el.nextElementSibling;
        if (cap && cap.classList && cap.classList.contains('fig-cap')) {
          return cap.textContent.trim().slice(0, 80) || 'Diagram';
        }
        return 'Diagram';
      }
      function enhance() {
        root.querySelectorAll('.mermaid').forEach(function (el) {
          if (!el.querySelector('svg')) return;
          if (!el.querySelector('.mzoom-btn')) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'mzoom-btn';
            btn.setAttribute('aria-label', 'Perbesar diagram');
            btn.innerHTML = EXPAND + '<span>Perbesar</span>';
            btn.addEventListener('click', function (ev) {
              ev.stopPropagation();
              returnFocus = btn;
              open(el.querySelector('svg'), labelFor(el));
            });
            el.appendChild(btn);
          }
          if (!el.dataset.mzBound) {
            el.dataset.mzBound = '1';
            var sx = 0, sy = 0;
            el.addEventListener('pointerdown', function (e) { sx = e.clientX; sy = e.clientY; });
            el.addEventListener('click', function (e) {
              if (e.target.closest('.mzoom-btn')) return;
              if (Math.abs(e.clientX - sx) > 6 || Math.abs(e.clientY - sy) > 6) return; // seleksi/scroll, bukan klik
              returnFocus = null;
              open(el.querySelector('svg'), labelFor(el));
            });
          }
        });
      }

      var pending = false;
      function schedule() {
        if (pending) return;
        pending = true;
        requestAnimationFrame(function () { pending = false; enhance(); });
      }
      new MutationObserver(schedule).observe(root, {
        childList: true,
        subtree: true,
        attributes: true,
        attributeFilter: ['data-processed'],
      });
      enhance();
    })();
  </script>
</BaseLayout>
