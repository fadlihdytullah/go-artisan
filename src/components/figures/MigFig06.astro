<svg viewBox="0 0 760 380" xmlns="http://www.w3.org/2000/svg" font-family="Inter, ui-sans-serif, system-ui, sans-serif">
  <rect x="16" y="16" width="728" height="348" rx="18" fill="#fbfaf5" stroke="#d9d4c4" stroke-width="2" />
  <text x="380" y="46" text-anchor="middle" font-size="19" fill="#241f17" font-weight="700">Spektrum Hybrid dan Edge: dari Region ke Lokasi Terpencil</text>
  <text x="380" y="66" text-anchor="middle" font-size="11" fill="#6e6a5c">Makin ke kanan, makin dekat ke pengguna atau lokasi fisik</text>

  <!-- axis -->
  <line x1="48" y1="124" x2="712" y2="124" stroke="#c6c0ac" stroke-width="2" />
  <text x="48" y="112" text-anchor="start" font-size="10" fill="#6e6a5c">pusat cloud</text>
  <text x="712" y="112" text-anchor="end" font-size="10" fill="#6e6a5c">tepi jaringan</text>

  <!-- 1 Region -->
  <rect x="40" y="138" width="128" height="118" rx="12" fill="#bd5d3e" />
  <circle cx="104" cy="128" r="7" fill="#bd5d3e" stroke="#fbfaf5" stroke-width="2" />
  <text x="104" y="166" text-anchor="middle" font-size="13" fill="#fbfaf5" font-weight="700">AWS Region</text>
  <text x="104" y="188" text-anchor="middle" font-size="10" fill="#f0e3d8">banyak AZ</text>
  <text x="104" y="204" text-anchor="middle" font-size="10" fill="#f0e3d8">layanan penuh</text>
  <text x="104" y="234" text-anchor="middle" font-size="10" fill="#fbfaf5" font-weight="700">baseline</text>

  <!-- 2 Local Zones -->
  <rect x="180" y="138" width="128" height="118" rx="12" fill="#fbfaf5" stroke="#0a7d6e" stroke-width="2" />
  <circle cx="244" cy="128" r="7" fill="#0a7d6e" stroke="#fbfaf5" stroke-width="2" />
  <text x="244" y="162" text-anchor="middle" font-size="12" fill="#0a7d6e" font-weight="700">Local Zones</text>
  <text x="244" y="184" text-anchor="middle" font-size="10" fill="#6e6a5c">metro / kota</text>
  <text x="244" y="200" text-anchor="middle" font-size="10" fill="#6e6a5c">latency 1 digit ms</text>
  <text x="244" y="230" text-anchor="middle" font-size="10" fill="#c14a39" font-weight="700">tidak in-scope</text>

  <!-- 3 Wavelength -->
  <rect x="320" y="138" width="128" height="118" rx="12" fill="#fbfaf5" stroke="#9c4a2f" stroke-width="2" />
  <circle cx="384" cy="128" r="7" fill="#9c4a2f" stroke="#fbfaf5" stroke-width="2" />
  <text x="384" y="162" text-anchor="middle" font-size="12" fill="#9c4a2f" font-weight="700">Wavelength</text>
  <text x="384" y="184" text-anchor="middle" font-size="10" fill="#6e6a5c">dalam jaringan 5G</text>
  <text x="384" y="200" text-anchor="middle" font-size="10" fill="#6e6a5c">ultra-low latency</text>
  <text x="384" y="230" text-anchor="middle" font-size="10" fill="#c14a39" font-weight="700">tidak in-scope</text>

  <!-- 4 Outposts -->
  <rect x="460" y="138" width="128" height="118" rx="12" fill="#bd5d3e" />
  <circle cx="524" cy="128" r="7" fill="#bd5d3e" stroke="#fbfaf5" stroke-width="2" />
  <text x="524" y="162" text-anchor="middle" font-size="12" fill="#fbfaf5" font-weight="700">Outposts</text>
  <text x="524" y="184" text-anchor="middle" font-size="10" fill="#f0e3d8">di data center</text>
  <text x="524" y="200" text-anchor="middle" font-size="10" fill="#f0e3d8">pelanggan</text>
  <text x="524" y="230" text-anchor="middle" font-size="10" fill="#fbfaf5" font-weight="700">in-scope</text>

  <!-- 5 Snow edge -->
  <rect x="600" y="138" width="128" height="118" rx="12" fill="#241f17" />
  <circle cx="664" cy="128" r="7" fill="#241f17" stroke="#fbfaf5" stroke-width="2" />
  <text x="664" y="162" text-anchor="middle" font-size="12" fill="#bd5d3e" font-weight="700">Snow Family</text>
  <text x="664" y="184" text-anchor="middle" font-size="10" fill="#fbfaf5">lokasi terpencil</text>
  <text x="664" y="200" text-anchor="middle" font-size="10" fill="#fbfaf5">terputus / rugged</text>
  <text x="664" y="230" text-anchor="middle" font-size="10" fill="#fbfaf5" font-weight="700">in-scope</text>

  <!-- drivers row -->
  <text x="104" y="296" text-anchor="middle" font-size="10" fill="#6e6a5c">pemicu: skala penuh</text>
  <text x="244" y="296" text-anchor="middle" font-size="10" fill="#6e6a5c">pemicu: latency metro</text>
  <text x="384" y="296" text-anchor="middle" font-size="10" fill="#6e6a5c">pemicu: latency 5G</text>
  <text x="524" y="296" text-anchor="middle" font-size="10" fill="#6e6a5c">pemicu: data residency</text>
  <text x="664" y="296" text-anchor="middle" font-size="10" fill="#6e6a5c">pemicu: tanpa koneksi</text>

  <rect x="40" y="318" width="688" height="32" rx="8" fill="#fbfaf5" stroke="#d9d4c4" stroke-width="1.5" />
  <text x="380" y="339" text-anchor="middle" font-size="11" fill="#241f17">Untuk CLF-C02, hanya Outposts dan Snow Family yang in-scope; Local Zones dan Wavelength bagus dipahami tetapi tidak resmi diuji</text>
</svg>
