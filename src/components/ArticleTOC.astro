---
// ArticleTOC.astro — "On this page" sticky sidebar.
// Ported from frame d4lirQ (Course Detail — Article/Direct). Mirrors the lesson
// TOC markup (data-toc-link anchors + .num + .active) so the existing scroll-spy
// script in ModuleLayout/BaseLayout lights the active item. Flat, rounded, v2
// tokens; scoped styles only (does NOT touch globals.css). Light + reader themes.
// Mobile: toggleable drawer (slides from left) instead of static card.

export interface ArticleTocItem {
  num?: string;
  id: string;
  title: string;
}

interface Props {
  toc: ArticleTocItem[];
  heading?: string;
}

const { toc, heading = 'On this page' } = Astro.props;
---

<button type="button" class="toc-fab" data-toc-fab aria-label="Buka daftar isi" aria-expanded="false">
  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18M3 12h12M3 18h18"/></svg>
</button>
<div class="toc-backdrop" data-toc-backdrop hidden></div>
<nav class="article-toc" aria-label={heading}>
  <div class="toc-drawer-head">
    <button type="button" class="toc-close" data-toc-close aria-label="Tutup daftar isi">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <span class="article-toc-eyebrow">{heading}</span>
  <ul class="article-toc-list">
    {toc.map((item) => (
      <li class="article-toc-item">
        <a href={`#${item.id}`} data-toc-link>
          {item.num && <span class="num">{item.num}</span>}
          <span class="t" set:html={item.title} />
        </a>
      </li>
    ))}
  </ul>
</nav>

<script is:inline>
  (function () {
    var fab = document.querySelector('[data-toc-fab]');
    var backdrop = document.querySelector('[data-toc-backdrop]');
    var closeBtn = document.querySelector('[data-toc-close]');
    var nav = document.querySelector('nav.article-toc');
    if (!fab || !nav) return;

    function isMobile() {
      return window.matchMedia('(max-width: 920px)').matches;
    }

    function open() {
      document.documentElement.classList.add('toc-open');
      fab.setAttribute('aria-expanded', 'true');
      if (backdrop) backdrop.hidden = false;
      if (isMobile()) nav.setAttribute('aria-hidden', 'false');
    }
    function close() {
      document.documentElement.classList.remove('toc-open');
      fab.setAttribute('aria-expanded', 'false');
      if (backdrop) backdrop.hidden = true;
      if (isMobile()) nav.setAttribute('aria-hidden', 'true');
    }

    fab.addEventListener('click', open);
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (backdrop) backdrop.addEventListener('click', close);

    var tocLinks = nav.querySelectorAll('a[data-toc-link]');
    tocLinks.forEach(function (link) {
      link.addEventListener('click', function () {
        setTimeout(close, 150);
      });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && document.documentElement.classList.contains('toc-open')) {
        close();
        fab.focus();
      }
    });
  })();
</script>

<style>
  /* Container — frame pNyWh: 330w, padded column, sticky. Garis pemisah kanan
     kini digambar oleh .article-layout::before (full-height) di tiap halaman,
     bukan border-right elemen sticky ini (yang terpotong setinggi isi TOC). */
  .article-toc {
    position: sticky;
    top: 96px;
    align-self: start;
    max-height: calc(100vh - 108px);
    overflow-y: auto;
    box-sizing: border-box;
    width: 100%;
    padding: 56px 36px 56px 44px;
    scrollbar-width: thin;
    scrollbar-color: var(--line-strong) transparent;
  }
  .article-toc::-webkit-scrollbar {
    width: 6px;
  }
  .article-toc::-webkit-scrollbar-thumb {
    background: var(--line-strong);
    border-radius: 999px;
  }

  /* Eyebrow — node TJsjU: "ON THIS PAGE", mono 11 / 600, +1.5 tracking, faint. */
  .article-toc-eyebrow {
    display: block;
    margin: 0 0 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--faint);
  }

  /* List — node Vbq1W: vertical, 2px gap. */
  .article-toc-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .article-toc-item {
    margin: 0;
  }

  /* Item — frame VH5q8/z3cdm: radius 8, pad 9/12, num↔title gap 13. */
  .article-toc a {
    display: flex;
    align-items: baseline;
    gap: 13px;
    padding: 9px 12px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  /* Num — mono 12 / 600, faint when idle. */
  .article-toc a .num {
    flex: none;
    min-width: 15px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--faint);
    transition: color 0.15s ease;
  }

  /* Title — Inter 14, line-height 1.4. Idle = ink / 500. */
  .article-toc a .t {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    color: var(--ink);
    transition: color 0.15s ease;
  }

  .article-toc a:hover {
    background: var(--paper-soft);
  }

  /* Active — frame VH5q8: accent-soft pill, accent-deep num + 600 title. */
  .article-toc a.active {
    background: var(--blue-soft);
  }
  .article-toc a.active .num,
  .article-toc a.active .t {
    color: var(--blue);
  }
  .article-toc a.active .t {
    font-weight: 600;
  }

  .toc-fab {
    display: none;
  }
  .toc-backdrop {
    display: none;
  }
  .toc-drawer-head {
    display: none;
  }

  @media (max-width: 920px) {
    .toc-fab {
      display: grid;
      place-items: center;
      position: fixed;
      bottom: 24px;
      left: 24px;
      width: 44px;
      height: 44px;
      border-radius: 999px;
      border: 1px solid var(--line-strong);
      background: var(--paper);
      color: var(--ink-soft);
      cursor: pointer;
      z-index: 50;
      transition: background-color 0.15s ease, color 0.15s ease, opacity 0.18s ease, transform 0.18s ease;
      box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }
    .toc-fab:hover {
      background: var(--paper-soft);
      color: var(--ink);
    }
    .toc-fab[aria-expanded="true"] {
      opacity: 0;
      pointer-events: none;
      transform: scale(0.8);
    }

    .toc-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 60;
      background: rgba(15, 23, 42, .5);
      backdrop-filter: blur(2px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.26s ease;
    }
    .toc-backdrop[hidden] {
      display: none;
    }
    html.toc-open .toc-backdrop {
      opacity: 1;
      pointer-events: auto;
    }

    .toc-drawer-head {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 4px;
    }
    .toc-close {
      width: 36px;
      height: 36px;
      border: 0;
      border-radius: var(--radius-sm);
      background: transparent;
      color: var(--ink-muted);
      cursor: pointer;
      display: grid;
      place-items: center;
    }
    .toc-close:hover {
      background: var(--line);
      color: var(--ink);
    }

    .article-toc {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 70;
      width: min(82vw, 320px);
      max-height: 100%;
      margin: 0;
      padding: 18px 18px 32px;
      border-right: 1px solid var(--line);
      border-radius: 0;
      background: var(--paper);
      transform: translateX(-100%);
      transition: transform 0.26s cubic-bezier(0.4, 0, 0.2, 1);
      overflow-y: auto;
    }
    html.toc-open .article-toc {
      transform: none;
    }
    .article-toc-eyebrow {
      margin-bottom: 12px;
    }
  }

  @media (max-width: 680px) {
    .toc-fab {
      left: 20px;
      bottom: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-toc {
      transition: none;
    }
    .toc-backdrop {
      transition: none;
    }
  }
</style>
