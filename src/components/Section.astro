---
// Satu section modul: nomor + judul + subjudul opsional, lalu konten.
// Markup identik dengan globals.css (.sec-head / .sec-num / .sec-sub).
interface Props {
  num: string;
  id: string;
  title: string;
  sub?: string;
}
const { num, id, title, sub } = Astro.props;
---
<section id={id}>
  <div class="sec-head">
    <div class="sec-num">{num}</div>
    <h2 set:html={title} />
  </div>
  {sub && <p class="sec-sub" set:html={sub} />}
  <slot />
</section>
